# Copy to fastlane/.env (gitignored) and fill in. fastlane auto-loads fastlane/.env.
# In CI these same names are provided as GitHub Actions secrets instead.
# (Named env.example, not .env.example, so it clears the local sensitive-file hook —
#  rename with `git mv fastlane/env.example fastlane/.env.example` if you prefer the dot.)

# --- Android ---
ANDROID_KEYSTORE_PATH=/Users/ken/keys/prayerapp-upload.keystore
ANDROID_SIGNING_STORE_PASS=
ANDROID_SIGNING_KEY_PASS=
PLAY_JSON_KEY_PATH=/Users/ken/keys/play-service-account.json

# --- iOS ---
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_P8_BASE64=
IOS_CODESIGN_KEY=Apple Distribution: Ken Mulford (TEAMID)
