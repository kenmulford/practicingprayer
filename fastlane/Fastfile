# Practicing Prayer release automation.
#
# Each lane BUILDS with dotnet, then UPLOADS with fastlane. The same lanes run
# locally (inputs from fastlane/.env) and in CI (inputs from GitHub secrets).
# fastlane's `sh` runs from the fastlane/ directory, so repo paths are "../"-relative.

# Absolute repo root, so paths work no matter which directory fastlane is invoked from.
# (git rev-parse, not __dir__/__FILE__ — those are broken in fastlane config files on Ruby 3.3+:
#  https://github.com/fastlane/fastlane/issues/29918)
ROOT    = `git rev-parse --show-toplevel`.strip
PROJECT = "#{ROOT}/PrayerApp/PrayerApp.csproj"
PACKAGE = "com.multithreadedllc.prayercards"

platform :android do
  desc "Build a signed AAB and upload to the Play internal track"
  lane :release do
    # The csproj reads ANDROID_SIGNING_STORE_PASS / ANDROID_SIGNING_KEY_PASS from ENV
    # (PrayerApp.csproj, signing PropertyGroup); we only point it at the keystore file.
    sh("dotnet", "publish", PROJECT, "-f", "net10.0-android", "-c", "Release",
       "-p:AndroidSigningKeyStore=#{ENV.fetch('ANDROID_KEYSTORE_PATH')}")

    aab = Dir["#{ROOT}/PrayerApp/bin/Release/net10.0-android/publish/*-Signed.aab"].first
    UI.user_error!("no signed AAB produced") unless aab

    upload_to_play_store(
      package_name: PACKAGE,
      aab: aab,
      json_key: ENV.fetch("PLAY_JSON_KEY_PATH"),
      track: "production",
      release_status: "draft", # full release created as a draft — you click "Send for review" in Play Console
      # Release notes come from fastlane/metadata/android/en-US/changelogs/default.txt (uploaded by default).
      # Leave the rest of the store listing alone — we only manage the binary + changelog.
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

platform :ios do
  desc "Build a signed IPA and upload to TestFlight"
  lane :release do
    key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true
    )

    # Signing comes from each project's own config — main app → iOS-signing.local.props,
    # extension → its csproj. NO -p:Codesign* args: command-line MSBuild props are global
    # and would override (and break) the extension's own signing. Mirrors the proven
    # manual deploy command exactly.
    sh("dotnet", "publish", PROJECT, "-f", "net10.0-ios", "-c", "Release", "-r", "ios-arm64")

    ipa = Dir["#{ROOT}/PrayerApp/bin/Release/net10.0-ios/ios-arm64/publish/*.ipa"].first
    UI.user_error!("no IPA produced") unless ipa

    upload_to_testflight(api_key: key, ipa: ipa, skip_waiting_for_build_processing: true)
  end
end
