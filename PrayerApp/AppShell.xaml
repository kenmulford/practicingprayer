<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PrayerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PrayerApp"
    xmlns:views="clr-namespace:PrayerApp.Views"
    Title="PrayerApp">

    <TabBar>

        <ShellContent
            Title="Home"
            Icon="house_solid_full.png"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Prayers"
            Icon="hands_praying_solid_full.png"
            ContentTemplate="{DataTemplate views:Prayer.PrayerMainView}"
            Route="PrayerMainView" />

        <ShellContent
            Title="Categories"
            Icon="list_solid_full.png"
            ContentTemplate="{DataTemplate views:Category.CategoryMainView}"
            Route="CategoryMainView" />

        <ShellContent
            Title="Settings"
            Icon="gear_solid_full.png"
            ContentTemplate="{DataTemplate views:Settings}"
            Route="Settings" />

    </TabBar>
</Shell>
