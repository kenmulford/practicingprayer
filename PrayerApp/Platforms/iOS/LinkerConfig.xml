<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Linker preservation rules for iOS AOT builds.
  Prevents the trimmer from stripping SQLite-net and SQLitePCLRaw internals,
  which causes "Failed to load AOT module 'SQLite-net'" at runtime.
-->
<linker>
  <!-- Preserve all sqlite-net-pcl types used via reflection (TableMapping, column accessors, etc.) -->
  <assembly fullname="SQLite-net" preserve="all" />

  <!-- Preserve SQLitePCLRaw core provider interface and raw API -->
  <assembly fullname="SQLitePCLRaw.core" preserve="all" />

  <!-- Preserve the bundled e_sqlite3 native provider wrapper -->
  <assembly fullname="SQLitePCLRaw.provider.e_sqlite3" preserve="all" />
</linker>
