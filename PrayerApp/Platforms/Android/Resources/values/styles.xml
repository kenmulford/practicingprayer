<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Match the window background to PageLight so no white flash appears before
         MAUI applies its theme. DayNight.NoActionBar matches MAUI's default parent. -->
    <style name="Maui.SplashTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/colorPageLight</item>
    </style>
</resources>
