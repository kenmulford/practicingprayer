<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0-android;net10.0-ios</TargetFrameworks>

		<MauiEnableXamlCBindingWithSourceCompilation>true</MauiEnableXamlCBindingWithSourceCompilation>

		<OutputType>Exe</OutputType>
		<RootNamespace>PrayerApp</RootNamespace>
		<UseMaui>true</UseMaui>
		<SingleProject>true</SingleProject>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!-- Display name -->
		<ApplicationTitle>Practicing Prayer</ApplicationTitle>

		<!-- App Identifier -->
		<ApplicationId>com.multithreadedllc.prayercards</ApplicationId>

		<!-- Versions -->
		<ApplicationDisplayVersion>1.3.1</ApplicationDisplayVersion>
		<ApplicationVersion>92</ApplicationVersion>

		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">16.0</SupportedOSPlatformVersion>
		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>
		<AndroidSigningKeyStore>prayerapp-release.keystore</AndroidSigningKeyStore>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|net10.0-ios|AnyCPU'">
	  <EnableSGenConc>False</EnableSGenConc>
	  <AdditionalArgs>ValidateXcodeVersion=false</AdditionalArgs>
	  <CodesignEntitlements>Platforms\iOS\Entitlements.plist</CodesignEntitlements>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Release|net10.0-ios|AnyCPU'">
	  <EnableSGenConc>False</EnableSGenConc>
	  <AdditionalArgs>ValidateXcodeVersion=false</AdditionalArgs>
	  <CodesignEntitlements>Platforms\iOS\Entitlements.plist</CodesignEntitlements>
	</PropertyGroup>

	<!--
	  iOS signing identity (CodesignKey + CodesignProvision) is per-developer.
	  Copy iOS-signing.local.props.example to iOS-signing.local.props (gitignored)
	  and fill in your own values. Without that file, builds fall through to
	  Xcode automatic signing — fine for simulator, will fail for device/Release.
	-->
	<Import Project="iOS-signing.local.props" Condition="Exists('iOS-signing.local.props')" />

	<!--
	  Android signing — passwords loaded from environment variables.
	  Set ANDROID_SIGNING_STORE_PASS and ANDROID_SIGNING_KEY_PASS in your
	  shell profile (or CI secrets) before building.
	  When the env vars are absent the build still succeeds (debug-signed).
	-->
	<PropertyGroup Condition="'$(TargetFramework)'=='net10.0-android' AND '$(ANDROID_SIGNING_STORE_PASS)'!=''">
	  <AndroidKeyStore>True</AndroidKeyStore>
	  <AndroidSigningKeyAlias>prayerapp</AndroidSigningKeyAlias>
	  <AndroidSigningStorePass>$(ANDROID_SIGNING_STORE_PASS)</AndroidSigningStorePass>
	  <AndroidSigningKeyPass>$(ANDROID_SIGNING_KEY_PASS)</AndroidSigningKeyPass>
	</PropertyGroup>

	<PropertyGroup Condition="'$(TargetFramework)'=='net10.0-ios'">
	  <!-- Xcode 26.2 and 26.3 have identical SDKs; skip the version check until workloads catch up -->
	  <ValidateXcodeVersion>false</ValidateXcodeVersion>
	  <ProvisioningType>manual</ProvisioningType>
	</PropertyGroup>

	<ItemGroup>
