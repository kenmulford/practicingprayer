	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Maui" Version="14.0.1" />
		<PackageReference Include="CommunityToolkit.Maui.Core" Version="14.0.1" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.1" />
		<PackageReference Include="Microsoft.Extensions.Http" Version="10.0.5" />
		<PackageReference Include="Microsoft.Maui.Controls" Version="10.0.50" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="10.0.5" />
		<PackageReference Include="Plugin.LocalNotification" Version="14.0.0" />
		<PackageReference Include="sqlite-net-pcl" Version="1.9.172" />
		<PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.10" />
	</ItemGroup>

	<!-- Linker preservation rules — prevents iOS AOT "SQLite-net out of date" crash -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
	  <TrimmerRootDescriptor Include="Platforms\iOS\LinkerConfig.xml" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Interfaces\" />
	</ItemGroup>

	<!-- Shared classlib for App Group constants, ImportPayload + source-gen JSON, and breadcrumb log. -->
	<ItemGroup>
	  <ProjectReference Include="..\PrayerApp.Shared\PrayerApp.Shared.csproj" />
	</ItemGroup>

	<!-- Embed the iOS Action Extension as an .appex inside the main app bundle. iOS-only. -->
	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
	  <ProjectReference Include="..\PrayerApp.ActionExtension\PrayerApp.ActionExtension.csproj">
	    <IsAppExtension>true</IsAppExtension>
	  </ProjectReference>
	</ItemGroup>

	<!-- Slice 4 F-27: build the host's own Metadata.appintents/ via a sibling
	     static-library Xcode project so WFInterchangeAppRegistry can resolve
	     com.multithreadedllc.prayercards. iOS-only. -->
	<Import Project="..\build\HostShortcuts.targets" Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'" />

	<ItemGroup>
	  <Compile Update="Views\PrayerCard\PrayerCardsPage.xaml.cs">
	    <DependentUpon>PrayerCardsPage.xaml</DependentUpon>
	  </Compile>
	  <Compile Update="Views\Prayer\PrayerDetailPage.xaml.cs">
	    <DependentUpon>PrayerDetailPage.xaml</DependentUpon>
	  </Compile>
	  <Compile Update="Views\Prayer\PrayerListPage.xaml.cs">
