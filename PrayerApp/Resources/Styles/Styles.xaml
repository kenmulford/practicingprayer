    <!-- Visual chrome strip-back (issue #33 P1 + P1A): no default Stroke/StrokeThickness;
         state cues (IsHighlighted, IsMultiSelected) flow through the CardStates VSM group
         below, driven by PrayerCardViewModel.CardVisualState via VisualStateBindingBehavior.
         Borders are surface-only at rest; Normal is the sole writer of StrokeThickness=0.
         Set Padding inline on each usage site; all other appearance props come from here. -->
    <Style x:Key="PrayerCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <Setter.Value>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CardStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Stroke" Value="Transparent" />
                                <Setter Property="StrokeThickness" Value="0" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Highlighted">
                            <VisualState.Setters>
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                                <Setter Property="StrokeThickness" Value="2.5" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="MultiSelected">
                            <VisualState.Setters>
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Setter Property="StrokeThickness" Value="2.5" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ActionChip: rounded action button for card actions (expanded view).
         Intentionally button-like: taller padding, rounder corners than tag pills. -->
    <Style x:Key="ActionChip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ChipBgLight}, Dark={StaticResource ChipBgDark}}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="14" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Base styles for BasedOn (compiled XAML does not support {x:Type} as a resource key) ── -->

    <!-- ButtonBase mirrors the implicit Button style so named variants can BasedOn it. -->
    <Style x:Key="ButtonBase" TargetType="Button">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <!-- LabelBase mirrors the implicit Label style so named variants can BasedOn it. -->
    <Style x:Key="LabelBase" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ── Picker styles (depend on LabelBase above) ──────────────────── -->

    <!-- PickerField: outlined dropdown border for Picker controls. -->
    <Style x:Key="PickerField" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PickerIndicator: decorative ▼ arrow inside a PickerField Grid column 1. -->
    <Style x:Key="PickerIndicator" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="Text" Value="▼" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Grid.Column" Value="1" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="false" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <!-- ── Button variants ─────────────────────────────────────────────── -->

    <!-- DangerButton: delete / destructive actions -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource DangerRed}, Dark={StaticResource DangerRed}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
    </Style>

    <!-- GhostButton: toolbar-style, transparent background -->
    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=Transparent, Dark=Transparent}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
    </Style>

    <!-- SmallActionButton: compact in-card actions (Set Reminder, Edit) -->
    <Style x:Key="SmallActionButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <!-- AnsweredButton: Mark Answered CTA — WarmGold + small.
         MUST follow SmallActionButton in this file (BasedOn dependency). -->
    <Style x:Key="AnsweredButton" TargetType="Button" BasedOn="{StaticResource SmallActionButton}">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
    </Style>

    <!-- CircleNavButton: Prayer Time previous/next arrows.
         Padding="0" overrides the default 14,10 — circle buttons need no internal padding.
         BackgroundColor and TextColor are left inline at each usage site (Prev vs. Next differ). -->
    <Style x:Key="CircleNavButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="WidthRequest" Value="60" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="20" />
    </Style>

    <!-- ── Label variants ────────────────────────────────────────────────── -->

    <!-- MutedText: secondary / de-emphasised text.
         Dark value uses TextMutedDark (#6b6f64) — subdued olive tone that reads as
         "muted" on the dark PageDark (#0d0e0c) background. -->
    <Style x:Key="MutedText" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}" />
    </Style>

    <!-- SuccessBadge: answered-date display (small, green) -->
    <Style x:Key="SuccessBadge" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource SuccessGreen}, Dark={StaticResource SuccessGreenDark}}" />
        <Setter Property="FontSize" Value="10" />
    </Style>

    <!-- FormLabel: field label above Entry/Editor/Picker -->
    <Style x:Key="FormLabel" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource PrimaryDark}}" />
    </Style>

    <!-- CardTitle: bold header inside a prayer card -->
    <Style x:Key="CardTitle" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="MaxLines" Value="3" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <!-- ── BoxView variant ───────────────────────────────────────────────── -->

    <!-- DividerLine: 1px horizontal rule using the BoxView-specific Color property.
         When applying this style, remove Color= OR BackgroundColor= (whichever is present),
         plus HeightRequest=, Opacity=, and HorizontalOptions= from the element. -->
    <Style x:Key="DividerLine" TargetType="BoxView">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="Opacity" Value="{AppThemeBinding Light=0.4, Dark=0.85}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
    </Style>

    <!-- CardContentLeftInsetMargin: shared 14pt left inset that aligns content with the
         cell-Border left edge on PrayerCardsPage (cell Border at PrayerCardsPage.xaml:470
         and the inter-cell separator below it both reference this). Issue #33 P1. -->
    <Thickness x:Key="CardContentLeftInsetMargin">14,0,0,0</Thickness>

    <!-- PickerInsetSeparator: subtle inset rule between rows inside a PickerGroupCard.
         Lighter than DividerLine (no Primary color, lower opacity) so it reads as
         structural-only rather than branded. Left-inset 16 matches PickerRow padding. -->
    <Style x:Key="PickerInsetSeparator" TargetType="BoxView">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="Opacity" Value="{AppThemeBinding Light=0.4, Dark=0.6}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Margin" Value="16,0,0,0" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
    </Style>

    <!-- PrayerListCard: rounded inset container for prayer rows within an expanded card.
         8px corner radius matches PrayerCardBorder; 1px stroke distinguishes it from the
         outer card. Background uses the PrayerListBg semantic color so it sits visually
         between CardLight and PageLight. -->
    <Style x:Key="PrayerListCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrayerListBgLight}, Dark={StaticResource PrayerListBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
        <Setter Property="Margin" Value="8,0,8,0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.06" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PrayerRow: transparent row inside a PrayerListCard. The card handles
         background color; rows are tap targets only. -->
    <Style x:Key="PrayerRow" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="16,11,12,11" />
    </Style>

    <!-- ── Picker group styles (iOS inset-grouped section pattern) ───────── -->

    <!-- PickerGroupCard: rounded section card containing picker rows.
         Matches iOS UITableView insetGrouped appearance. -->
    <Style x:Key="PickerGroupCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PickerSectionHeader: small gray label above each PickerGroupCard.
         Approximates iOS section header — small, muted, no bold. -->
    <Style x:Key="PickerSectionHeader" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="0.3" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}" />
    </Style>

    <!-- PickerRow: transparent tap-target row inside a PickerGroupCard.
         Generous padding matches iOS table row insets. No stroke (card handles border). -->
    <Style x:Key="PickerRow" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="16,13" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource PageDark}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource PageDark}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray950}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource TabBarDark}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TabUnselectedDark}}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource PageDark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource TabBarDark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="UnselectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource TabUnselectedDark}}" />
        <Setter Property="SelectedTabColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
    </Style>

</ResourceDictionary>
