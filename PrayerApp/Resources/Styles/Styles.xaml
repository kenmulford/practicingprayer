<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Accessibility tokens — touch-target floors (PS-06, issue #51) ────
         iOS HIG floor = 44pt; Material 3 floor = 48dp. 44 is the stricter
         cross-platform minimum that satisfies iOS without bloating Android.
         Centralizing as a named token makes the floor reviewable in one
         place; future interactive rows can reference the same key. -->
    <x:Double x:Key="TouchTargetMinimum">44</x:Double>

    <!-- ── Typography font-size tokens (PS-05, issue #51) ────────────────────
         14-step ladder covering every FontSize literal used in PrayerApp
         XAML. Names are semantic with the numeric size tied to a short
         comment so the design intent is visible at the callsite AND the
         rendered pixel size is unambiguous when grepping for a literal.
         The ladder mirrors values already in use — no resize, pure
         value-preserving refactor.
         Out of scope for PS-05: LineHeight, LetterSpacing, FontFamily. -->
    <x:Double x:Key="FontMicro">10</x:Double>
    <x:Double x:Key="FontTiny">11</x:Double>
    <x:Double x:Key="FontCaption">12</x:Double>
    <x:Double x:Key="FontSmall">13</x:Double>
    <x:Double x:Key="FontBody">14</x:Double>
    <x:Double x:Key="FontBodyLg">15</x:Double>
    <x:Double x:Key="FontHeadline">16</x:Double>
    <x:Double x:Key="FontTitle">17</x:Double>
    <x:Double x:Key="FontTitleLg">18</x:Double>
    <x:Double x:Key="FontHeading">20</x:Double>
    <x:Double x:Key="FontHeadingLg">22</x:Double>
    <x:Double x:Key="FontDisplay">24</x:Double>
    <x:Double x:Key="FontDisplayLg">28</x:Double>
    <x:Double x:Key="FontHero">32</x:Double>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
    </Style>

    <Style x:Key="SaveActivityIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style TargetType="IndicatorView">
        <Setter Property="IndicatorColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"/>
        <Setter Property="SelectedIndicatorColor" Value="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}"/>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="StrokeShape" Value="Rectangle"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}" />
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <!-- No FontFamily — let iOS use system font so AM/PM glyphs render correctly -->
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <!-- Focus tint: Secondary (#E8EDE3) light pops against CardLight white;
                                 ChipFavoritedBgDark (#3A3420) dark provides ~34-unit lift over CardDark
                                 (#181a16) plus a warm-gold hue cast, mirroring the light-side
                                 "lift + hue" strategy and matching the warm journal palette. -->
                            <Setter Property="BackgroundColor"
                                    Value="{AppThemeBinding Light={StaticResource Secondary},
                                                            Dark={StaticResource ChipFavoritedBgDark}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <!-- Focus tint: see Editor style above for token rationale. -->
                            <Setter Property="BackgroundColor"
                                    Value="{AppThemeBinding Light={StaticResource Secondary},
                                                            Dark={StaticResource ChipFavoritedBgDark}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.5" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver" />
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Span">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="Label" x:Key="Headline">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DeepEarth}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontSize" Value="{StaticResource FontHero}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="SemanticProperties.HeadingLevel" Value="Level1" />
    </Style>

    <Style TargetType="Label" x:Key="SubHeadline">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DeepEarth}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontSize" Value="{StaticResource FontDisplay}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SectionHeading">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DeepEarth}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontSize" Value="{StaticResource FontTitleLg}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="SemanticProperties.HeadingLevel" Value="Level2" />
    </Style>

    <Style TargetType="Label" x:Key="SectionDescription">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="FontSize" Value="{StaticResource FontSmall}" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="SeparatorColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" />
        <Setter Property="RefreshControlColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray200}}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="CancelButtonColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SearchHandler">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Shadow">
        <Setter Property="Radius" Value="15" />
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Brush" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
        <Setter Property="Offset" Value="10,10" />
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="MinimumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                            <Setter Property="MaximumTrackColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray200}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray600}}" />
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="On">
                        <VisualState.Setters>
                            <!-- Dark: Primary green track so white thumb is clearly visible -->
                            <Setter Property="OnColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource Secondary}}" />
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Off">
                        <VisualState.Setters>
                            <Setter Property="ThumbColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray200}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <!-- No FontFamily — let iOS use system font so AM/PM glyphs render correctly -->
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Visual chrome strip-back (issue #33 P1 + P1A): no default Stroke/StrokeThickness;
         state cues (IsHighlighted, IsMultiSelected) flow through the CardStates VSM group
         below, driven by PrayerCardViewModel.CardVisualState via VisualStateBindingBehavior.
         Borders are surface-only at rest; Normal is the sole writer of StrokeThickness=0.
         Set Padding inline on each usage site; all other appearance props come from here. -->
    <Style x:Key="PrayerCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <Setter.Value>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CardStates">
                        <VisualState x:Name="Normal">
                            <VisualState.Setters>
                                <Setter Property="Stroke" Value="Transparent" />
                                <Setter Property="StrokeThickness" Value="0" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Highlighted">
                            <VisualState.Setters>
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                                <Setter Property="StrokeThickness" Value="2.5" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="MultiSelected">
                            <VisualState.Setters>
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                <Setter Property="StrokeThickness" Value="2.5" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ActionChip: rounded action button for card actions (expanded view).
         Intentionally button-like: taller padding, rounder corners than tag pills. -->
    <Style x:Key="ActionChip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ChipBgLight}, Dark={StaticResource ChipBgDark}}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="14" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Base styles for BasedOn (compiled XAML does not support {x:Type} as a resource key) ── -->

    <!-- ButtonBase mirrors the implicit Button style so named variants can BasedOn it. -->
    <Style x:Key="ButtonBase" TargetType="Button">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize" Value="{StaticResource FontBody}"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}"/>
        <Setter Property="MinimumWidthRequest" Value="44"/>
    </Style>

    <!-- LabelBase mirrors the implicit Label style so named variants can BasedOn it. -->
    <Style x:Key="LabelBase" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
    </Style>

    <!-- ── Picker styles (depend on LabelBase above) ──────────────────── -->

    <!-- PickerIndicator: decorative ▼ arrow used by the shared StyledPicker chrome. -->
    <Style x:Key="PickerIndicator" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="Text" Value="▼" />
        <Setter Property="FontSize" Value="{StaticResource FontCaption}" />
        <Setter Property="Grid.Column" Value="1" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="false" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <!-- ── Button variants ─────────────────────────────────────────────── -->

    <!-- DangerButton: delete / destructive actions -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource DangerRed}, Dark={StaticResource DangerRed}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
    </Style>

    <!-- GhostButton: toolbar-style, transparent background -->
    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=Transparent, Dark=Transparent}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
    </Style>

    <!-- SmallActionButton: compact in-card actions (Set Reminder, Edit) -->
    <Style x:Key="SmallActionButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="FontSize" Value="{StaticResource FontSmall}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <!-- AnsweredButton: Mark Answered CTA — WarmGold + small.
         MUST follow SmallActionButton in this file (BasedOn dependency). -->
    <Style x:Key="AnsweredButton" TargetType="Button" BasedOn="{StaticResource SmallActionButton}">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
    </Style>

    <!-- CircleNavButton: Prayer Time previous/next arrows.
         Padding="0" overrides the default 14,10 — circle buttons need no internal padding.
         BackgroundColor and TextColor are left inline at each usage site (Prev vs. Next differ). -->
    <Style x:Key="CircleNavButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="WidthRequest" Value="60" />
        <Setter Property="HeightRequest" Value="60" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource FontHeading}" />
    </Style>

    <!-- ── Label variants ────────────────────────────────────────────────── -->

    <!-- MutedText: secondary / de-emphasised text.
         Dark value uses TextMutedDark (#6b6f64) — subdued olive tone that reads as
         "muted" on the dark PageDark (#0d0e0c) background. -->
    <Style x:Key="MutedText" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}" />
    </Style>

    <!-- SuccessBadge: answered-date display (small, green) -->
    <Style x:Key="SuccessBadge" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource SuccessGreen}, Dark={StaticResource SuccessGreenDark}}" />
        <Setter Property="FontSize" Value="{StaticResource FontMicro}" />
    </Style>

    <!-- FormLabel: field label above Entry/Editor/Picker.
         Issue #47 — light-mode token shifted from Tertiary (#3F4A34) to Gray500 (#6E6E6E)
         so the field label reads as secondary text against the primary Entry/Editor text
         (Gray900). Dark stays at PrimaryDark (the dark-mode secondary token used across
         form chrome). Apple HIG / Material 3 both treat field labels as secondary text;
         this brings the token in line with MutedText / PickerSectionHeader / SectionDescription
         / CardsSectionHeader, which all use Gray500 light / TextSecondaryDark dark. -->
    <Style x:Key="FormLabel" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="{StaticResource FontSmall}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource PrimaryDark}}" />
    </Style>

    <!-- CardTitle: bold header inside a prayer card -->
    <Style x:Key="CardTitle" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="{StaticResource FontTitle}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="MaxLines" Value="3" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
    </Style>

    <!-- ── BoxView variant ───────────────────────────────────────────────── -->

    <!-- DividerLine: 1px horizontal rule using the BoxView-specific Color property.
         When applying this style, remove Color= OR BackgroundColor= (whichever is present),
         plus HeightRequest=, Opacity=, and HorizontalOptions= from the element. -->
    <Style x:Key="DividerLine" TargetType="BoxView">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="Opacity" Value="{AppThemeBinding Light=0.4, Dark=0.85}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
    </Style>

    <!-- CardContentLeftInsetMargin: shared 14pt left inset that aligns content with the
         cell-Border left edge on PrayerCardsPage (cell Border at PrayerCardsPage.xaml:470
         and the inter-cell separator below it both reference this). Issue #33 P1. -->
    <Thickness x:Key="CardContentLeftInsetMargin">14,0,0,0</Thickness>

    <!-- PickerInsetSeparator: subtle inset rule between rows inside a PickerGroupCard.
         Lighter than DividerLine (no Primary color, lower opacity) so it reads as
         structural-only rather than branded. Left-inset 16 matches PickerRow padding. -->
    <Style x:Key="PickerInsetSeparator" TargetType="BoxView">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="Opacity" Value="{AppThemeBinding Light=0.4, Dark=0.6}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Margin" Value="16,0,0,0" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
    </Style>

    <!-- PrayerRow: transparent row inside an expanded prayer card. The card handles
         background color; rows are tap targets only. -->
    <Style x:Key="PrayerRow" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="16,11,12,11" />
    </Style>

    <!-- ── Picker group styles (iOS inset-grouped section pattern) ───────── -->

    <!-- PickerGroupCard: rounded section card containing picker rows.
         Matches iOS UITableView insetGrouped appearance. -->
    <Style x:Key="PickerGroupCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PickerSectionHeader: small gray label above each PickerGroupCard.
         Approximates iOS section header — small, muted, no bold. -->
    <Style x:Key="PickerSectionHeader" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="FontSize" Value="{StaticResource FontCaption}" />
        <Setter Property="CharacterSpacing" Value="0.3" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <!-- CardsSectionHeader: outer group header on PrayerCardsPage (e.g. "Loose Cards", "Family").
         Issue #33 P4 — per-platform visual language.
           iOS — UPPERCASE via Label.TextTransform, +0.3 character-spacing, 13pt;
                 matches iOS Settings/Mail UITableView grouped section convention.
                 Tightened from 0.6 → 0.3 (issue #33 UAT-9) to reduce small-caps + tracking
                 shimmer on dark backgrounds; uppercase group labels carry less tracking on
                 dark than light per Apple Settings.app convention.
           Android — normal-case, bold (Material 3 Title Small approximation), 13pt,
                     no letterspacing.
         Sized at 13pt to set the outer-group level; the inner expanded-card "Prayers"
         header is 15pt Bold (UAT-8) so hierarchy reads via weight + treatment, not size. -->
    <Style x:Key="CardsSectionHeader" TargetType="Label" BasedOn="{StaticResource LabelBase}">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="FontSize" Value="{StaticResource FontSmall}" />
        <Setter Property="CharacterSpacing">
            <Setter.Value>
                <OnPlatform x:TypeArguments="x:Double" Default="0">
                    <On Platform="iOS, MacCatalyst" Value="0.3" />
                </OnPlatform>
            </Setter.Value>
        </Setter>
        <Setter Property="FontAttributes">
            <Setter.Value>
                <OnPlatform x:TypeArguments="FontAttributes" Default="None">
                    <On Platform="Android" Value="Bold" />
                </OnPlatform>
            </Setter.Value>
        </Setter>
        <Setter Property="TextTransform">
            <Setter.Value>
                <OnPlatform x:TypeArguments="TextTransform" Default="None">
                    <On Platform="iOS, MacCatalyst" Value="Uppercase" />
                </OnPlatform>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- FormSectionHeader: outer section title above a PrayerCardBorder section card on
         edit forms and settings surfaces. Issue #47. Inherits iOS uppercase / 0.3 character
         spacing / 13pt / Gray500-light treatment from CardsSectionHeader; overrides to Bold
         on all platforms (differentiates the section header from in-card FormLabel, which
         is also Gray500 13pt). Distinct from SectionHeading (18pt Bold) which remains a
         page-level heading on TagPickerPage. Per-call-site SemanticProperties.HeadingLevel
         remains the project convention; not baked into the style. -->
    <Style x:Key="FormSectionHeader" TargetType="Label" BasedOn="{StaticResource CardsSectionHeader}">
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- PickerRow: transparent tap-target row inside a PickerGroupCard.
         Generous padding matches iOS table row insets. No stroke (card handles border). -->
    <Style x:Key="PickerRow" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="16,13" />
    </Style>

    <!-- ── SettingsHubPage row composites (PS-03, issue #51) ─────────────────
         Five-element row template used 5x on SettingsHubPage. Per-row variance:
         AutomationId, Tapped handler, Image.Source, title Text, subtitle Text.
         IconTintColorBehavior stays inline on each Image (Behaviors cannot be
         set as Style setter values). Font sizes route through PS-05 typography
         tokens; touch-target floor via TouchTargetMinimum (PS-06). -->

    <Style x:Key="SettingsRowGrid" TargetType="Grid">
        <Setter Property="ColumnDefinitions" Value="Auto,*,Auto" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="MinimumHeightRequest" Value="{StaticResource TouchTargetMinimum}" />
    </Style>

    <Style x:Key="SettingsRowIcon" TargetType="Image">
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,0,14,0" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
    </Style>

    <Style x:Key="SettingsRowTitle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontHeadline}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style x:Key="SettingsRowSubtitle" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSmall}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <Style x:Key="SettingsRowChevron" TargetType="Label">
        <Setter Property="Text" Value="›" />
        <Setter Property="FontSize" Value="{StaticResource FontHeading}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
    </Style>

    <!-- ── MainPage metric-tile composites (PS-04, issue #51) ───────────────
         4 base styles for the 2x2 metric grid on MainPage. Applied to the
         Active Cards, Unanswered, Last Prayed, and Overdue tiles.
         Per-tile divergences stay inline:
           - LastPrayedDay uses FontSize=32 (not 28)
           - Overdue count uses WarmGold (not Tertiary)
           - Overdue empty-state is a checkmark VerticalStackLayout (not a Label)
           - Overdue Border.Triggers (warm-gold highlight) stays on the Border
         Font sizes route through PS-05 typography tokens. -->

    <Style x:Key="MetricTileLabel" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontTiny}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
    </Style>

    <Style x:Key="MetricTileNumber" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontDisplayLg}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style x:Key="MetricTileEmpty" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontSmall}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource TextMutedDark}}" />
    </Style>

    <Style x:Key="MetricTileTapHint" TargetType="Label">
        <Setter Property="FontSize" Value="{StaticResource FontMicro}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="AutomationProperties.IsInAccessibleTree" Value="False" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource PageDark}}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource PageDark}}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray950}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource TabBarDark}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource TabUnselectedDark}}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource PageDark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource PageLight}, Dark={StaticResource TabBarDark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
        <Setter Property="UnselectedTabColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource TabUnselectedDark}}" />
        <Setter Property="SelectedTabColor" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
    </Style>

</ResourceDictionary>
