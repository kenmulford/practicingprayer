<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#6B7D5A</Color>
    <Color x:Key="PrimaryDark">#A8B896</Color>
    <Color x:Key="PrimaryDarkText">#1C2415</Color>
    <Color x:Key="Secondary">#E8EDE3</Color>
    <Color x:Key="SecondaryDarkText">#7A8C68</Color>
    <Color x:Key="Tertiary">#3F4A34</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="WarmGold">#C4A052</Color>
    <Color x:Key="WarmGoldDark">#d4b062</Color>
    <Color x:Key="DeepEarth">#2D3428</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="SuccessGreen">#2E7D32</Color>
    <Color x:Key="SuccessGreenDark">#66BB6A</Color>
    <Color x:Key="DangerRed">#CD5C5C</Color>
    <Color x:Key="DangerRedDark">#E07070</Color>

    <!-- Warm Journal theme — semantic surface colors -->
    <Color x:Key="PageLight">#FAF8F3</Color>
    <Color x:Key="PageDark">#0d0e0c</Color>
    <Color x:Key="CardLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#181a16</Color>
    <Color x:Key="SurfaceDark">#1c1e19</Color>
    <Color x:Key="TabBarDark">#0a0b09</Color>
    <Color x:Key="ButtonSecondaryLight">#E8EDE3</Color>
    <Color x:Key="ButtonSecondaryDark">#252722</Color>
    <Color x:Key="PrimaryBtnDark">#7d8e6c</Color>
    <Color x:Key="TextPrimaryDark">#dce0d5</Color>
    <Color x:Key="TextSecondaryDark">#9a9e92</Color>
    <Color x:Key="TextMutedDark">#858981</Color>
    <Color x:Key="TabUnselectedDark">#4a4d46</Color>
    <Color x:Key="OverdueLight">#FFF8E7</Color>
    <Color x:Key="OverdueDark">#1a1810</Color>
    <Color x:Key="CardBorderDark">#2a2e26</Color>
    <Color x:Key="SystemCardLight">#F0F3EC</Color>
    <Color x:Key="SystemCardDark">#1e201b</Color>
    <!-- Inset background for prayer request rows within expanded cards.
         Distinct from CardLight (not pure white) without washing out to PageLight. -->
    <Color x:Key="PrayerListBgLight">#F0F3EC</Color>
    <Color x:Key="PrayerListBgDark">#4D4F4A</Color>
    <!-- Expanded (active) prayer card — subtle "lifted paper" tint used with a soft Shadow -->
    <Color x:Key="CardExpandedLight">#FFFAF0</Color>
    <Color x:Key="CardExpandedDark">#20221D</Color>

    <!-- Action chip backgrounds -->
    <Color x:Key="ChipBgLight">#F0F0F0</Color>
    <Color x:Key="ChipBgDark">#2A2E26</Color>
    <Color x:Key="ChipFavoritedBgLight">#F5EDD4</Color>
    <Color x:Key="ChipFavoritedBgDark">#3A3420</Color>
    <Color x:Key="ChipDangerBgLight">#FDE8E8</Color>
    <Color x:Key="ChipDangerBgDark">#3A1B1B</Color>

    <!-- Loading-overlay scrim — translucent backdrop behind ActivityIndicator. -->
    <Color x:Key="LoadingScrimLight">#66000000</Color>
    <Color x:Key="LoadingScrimDark">#A6000000</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#717171</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray700">#333333</Color>
    <Color x:Key="Gray800">#2B2B2B</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Tag color palette — 8 hues, light + dark mode variants, all use White text -->
    <!-- Light: dark-enough for white text on chip backgrounds -->
    <!-- Dark: brighter for visibility on dark page backgrounds -->
    <Color x:Key="TagRed">#B84040</Color>
    <Color x:Key="TagRedDark">#D46060</Color>
    <Color x:Key="TagOrange">#B35A20</Color>
    <Color x:Key="TagOrangeDark">#CC7040</Color>
    <Color x:Key="TagBrown">#7A4020</Color>
    <Color x:Key="TagBrownDark">#A65C34</Color>
    <Color x:Key="TagTeal">#1E7870</Color>
    <Color x:Key="TagTealDark">#3AA898</Color>
    <Color x:Key="TagBlue">#2E5A9A</Color>
    <Color x:Key="TagBlueDark">#507ACC</Color>
    <Color x:Key="TagPurple">#663C8C</Color>
    <Color x:Key="TagPurpleDark">#9460C0</Color>
    <Color x:Key="TagPink">#8C3860</Color>
    <Color x:Key="TagPinkDark">#B85A8C</Color>
    <Color x:Key="TagGray">#505050</Color>
    <Color x:Key="TagGrayDark">#848484</Color>
    <!-- All tag chip foreground text uses White regardless of mode -->
    <Color x:Key="TagText">White</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}"/>
    <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
