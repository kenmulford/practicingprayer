<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PrayerApp.Views.Shared"
             x:Class="PrayerApp.Views.Shared.LoadingOverlay"
             x:Name="overlayRoot"
             IsVisible="{Binding IsLoading, Source={x:Reference overlayRoot}, x:DataType=local:LoadingOverlay}">
    <!-- Grid fills the parent cell; with a non-null background it absorbs touches
         during loading. Host pages should set Grid.RowSpan/ColumnSpan so the
         overlay covers the full visual area, not just one cell. -->
    <Grid BackgroundColor="{AppThemeBinding Light={StaticResource LoadingScrimLight}, Dark={StaticResource LoadingScrimDark}}">
        <ActivityIndicator Style="{StaticResource SaveActivityIndicator}"
                           IsRunning="{Binding IsLoading, Source={x:Reference overlayRoot}, x:DataType=local:LoadingOverlay}" />
    </Grid>
</ContentView>
