<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.Settings"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout
            Padding="20,16"
            Spacing="16">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackgroundTapped" />
            </VerticalStackLayout.GestureRecognizers>

            <!-- Notifications -->
            <Border Style="{StaticResource PrayerCardBorder}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Notifications"
                        Style="{StaticResource SectionHeading}" />
                    <Grid
                        ColumnDefinitions="*, Auto"
                        ColumnSpacing="12"
                        HorizontalOptions="Fill">
                        <Label
                            Text="Allow Notifications"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="chkSettingsAllowNotifications"
                            Grid.Column="1"
                            AutomationId="Settings_Switch_Notifications"
                            SemanticProperties.Description="Allow the app to send prayer reminder notifications"
                            Toggled="chkSettingsAllowNotifications_Toggled" />
                    </Grid>
                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding Source={x:Reference chkSettingsAllowNotifications}, Path=IsToggled, x:DataType=Switch}">
                        <Label Text="Default Reminder Time"
                               Style="{StaticResource FormLabel}" />
                        <TimePicker x:Name="timePickerDefaultNotify"
                                    AutomationId="Settings_Picker_ReminderTime"
                                    PropertyChanged="timePickerDefaultNotify_PropertyChanged"
                                    SemanticProperties.Description="Default time of day for prayer reminders" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Prayer Reminders -->
            <Border Style="{StaticResource PrayerCardBorder}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Prayer Reminders"
                        Style="{StaticResource SectionHeading}" />
                    <Label
                        Text="Prayers not prayed within this many days appear in your overdue list on the home page."
                        Style="{StaticResource SectionDescription}" />
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Overdue after (days)"
                               Style="{StaticResource FormLabel}" />
                        <Entry x:Name="entryOverdueThreshold"
                               AutomationId="Settings_Entry_OverdueThreshold"
                               Keyboard="Numeric"
                               ReturnType="Done"
                               Placeholder="30"
                               TextChanged="entryOverdueThreshold_TextChanged"
                               HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Backup & Restore -->
            <Border Style="{StaticResource PrayerCardBorder}" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Backup &amp; Restore"
                        Style="{StaticResource SectionHeading}" />
                    <Label
                        Text="Export your prayer data to a file you can restore on another device."
                        Style="{StaticResource SectionDescription}" />
                    <Button
                        x:Name="btnBackup"
                        Text="Back Up Now"
                        AutomationId="Settings_Btn_Backup"
                        Clicked="btnBackup_Clicked"
                        HorizontalOptions="Fill"
                        Margin="0,4,0,0" />
                    <Button
                        x:Name="btnRestore"
                        Text="Restore from Backup"
                        AutomationId="Settings_Btn_Restore"
                        Clicked="btnRestore_Clicked"
                        HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <!-- Diagnostics — entire card hidden when no log file exists -->
            <Border x:Name="diagnosticsSection"
                    Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="False">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Diagnostics"
                        Style="{StaticResource SectionHeading}" />
                    <Label
                        Text="If you're experiencing issues, send this log to help us diagnose the problem."
                        Style="{StaticResource SectionDescription}" />
                    <Button
                        x:Name="btnSendDiagnostics"
                        Text="Send Diagnostic Info"
                        AutomationId="Settings_Btn_Diagnostics"
                        Clicked="btnSendDiagnostics_Clicked"
                        HorizontalOptions="Fill"
                        Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Privacy Policy -->
            <Button x:Name="BtnPrivacyPolicy"
                    Text="Privacy Policy"
                    AutomationId="Settings_Btn_PrivacyPolicy"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    BackgroundColor="Transparent"
                    FontSize="14"
                    Padding="0"
                    BorderWidth="0"
                    Margin="0,4,0,0"
                    HorizontalOptions="Start" />

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>
