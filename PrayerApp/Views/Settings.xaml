<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.Settings"
             Title="App Settings">
    <ScrollView>
        <VerticalStackLayout
            Padding="20,5"
            Spacing="5">
            <Grid
                ColumnDefinitions="*, Auto"
                ColumnSpacing="12"
                RowDefinitions="Auto,Auto"
                HorizontalOptions="Fill"
                VerticalOptions="Center"
                RowSpacing="8">
                <Label
                    Text="Clear Settings" />
                <Button
                    x:Name="btnClearSettings"
                    Grid.Column="1"
                    HorizontalOptions="End"
                    Clicked="btnClearSettings_Clicked"
                    Text="Go" />

                <Label
                    Grid.Row="1"
                    Text="Allow Notifications?" />
                <Switch
                    x:Name="chkSettingsAllowNotifications"
                    Grid.Row="1"
                    Grid.Column="1"
                    SemanticProperties.Description="Allow the app to send prayer reminder notifications"
                    OnColor="{StaticResource Secondary}"
                    Toggled="chkSettingsAllowNotifications_Toggled">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="On">
                                    <VisualState.Setters>
                                        <Setter Property="ThumbColor"
                                            Value="{StaticResource Primary}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Off">
                                    <VisualState.Setters>
                                        <Setter Property="ThumbColor"
                                            Value="{StaticResource Gray600}" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
                </Switch>
            </Grid>
            <!-- Online Backup -->
            <Label
                Text="Online Backup"
                Style="{StaticResource Headline}"
                Margin="0,20,0,4" />
            <Label
                Text="Export your prayer data to a file you can restore on another device."
                Style="{StaticResource SubHeadline}"
                Margin="0,0,0,8" />
            <Button
                x:Name="btnBackup"
                Text="Back Up Now"
                Clicked="btnBackup_Clicked"
                HorizontalOptions="Fill" />
            <Button
                x:Name="btnRestore"
                Text="Restore from Backup"
                Clicked="btnRestore_Clicked"
                HorizontalOptions="Fill"
                Margin="0,8,0,0" />

            <!-- Diagnostics -->
            <Label
                Text="Diagnostics"
                Style="{StaticResource Headline}"
                Margin="0,20,0,4" />
            <Label
                Text="If you're experiencing issues, send this log to help us diagnose the problem."
                Style="{StaticResource SubHeadline}"
                Margin="0,0,0,8" />
            <Button
                x:Name="btnSendDiagnostics"
                Text="Send Diagnostic Info"
                Clicked="btnSendDiagnostics_Clicked"
                HorizontalOptions="Fill"
                IsVisible="False" />

            <!-- Privacy Policy -->
            <Label x:Name="LblPrivacyPolicy"
                   Text="Privacy Policy"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                   TextDecorations="Underline"
                   FontSize="14"
                   Margin="0,12,0,0"
                   HorizontalOptions="Start">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer x:Name="TapPrivacyPolicy" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>