<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             xmlns:shared="clr-namespace:PrayerApp.Views.Shared"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardPage"
             x:DataType="viewModels:PrayerCardViewModel"
             Title="Prayer Card"
             SafeAreaEdges="Container">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save"
                     Command="{Binding SaveCommand}"
                     SemanticProperties.Hint="Save prayer card changes"
                     x:DataType="viewModels:PrayerCardViewModel" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="12,8" Spacing="16">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackgroundTapped" />
                </VerticalStackLayout.GestureRecognizers>

                <Border Style="{StaticResource PrayerCardBorder}" Padding="0">
                    <VerticalStackLayout Spacing="0">

                        <!-- Row 1: Title (HIG label-above-field for free-text) -->
                        <VerticalStackLayout Padding="16,11" Spacing="6">
                            <Label Text="Title" Style="{StaticResource FormLabel}" />
                            <Entry x:Name="TitleEntry"
                                   Text="{Binding Title}"
                                   AutomationId="Card_Entry_Title"
                                   IsReadOnly="{Binding IsSystem}"
                                   HorizontalOptions="Fill"
                                   Placeholder="Card title"
                                   SemanticProperties.Hint="Name or topic for this prayer card" />
                        </VerticalStackLayout>

                        <!-- Row 2 (non-system cards only): Collection picker (HIG disclosure-row).
                             Wraps separator + row so the hairline collapses with the picker for system cards. -->
                        <VerticalStackLayout Spacing="0"
                                             IsVisible="{Binding IsSystem, Converter={StaticResource InverseBool}}">
                            <BoxView Style="{StaticResource PickerInsetSeparator}" />
                            <Grid Padding="16,11" ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                       Text="Collection"
                                       Style="{StaticResource FormLabel}"
                                       VerticalOptions="Center" />
                                <shared:StyledPicker Grid.Column="1"
                                                     ItemsSource="{Binding AvailableBoxes}"
                                                     SelectedItem="{Binding SelectedBox}"
                                                     AutomationId="Card_Picker_Box"
                                                     SemanticHint="Choose which collection this card belongs to"
                                                     VerticalOptions="Center"
                                                     HorizontalOptions="Fill"
                                                     HorizontalTextAlignment="End" />
                            </Grid>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Delete Button — Save is in the navbar, Share is on the expanded card view.
                     Outside the section card (different state, not a row in the group). -->
                <Button Text="Delete"
                        AutomationId="Card_Btn_Delete"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding CanDelete}"
                        HorizontalOptions="Fill" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — NameCard step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameCard"
            HeadlineText="Give it a name — a person, a topic, your church"
            SubText="Then tap Save." />

        <!-- Save indicator -->
        <ActivityIndicator Grid.Row="0" Grid.RowSpan="2"
                           Style="{StaticResource SaveActivityIndicator}"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}" />

    </Grid>
</ContentPage>
