<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardPage"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:DataType="viewModels:PrayerCardViewModel"
             Title="Prayer Card">
    <ContentPage.BindingContext>
        <viewModels:PrayerCardViewModel />
    </ContentPage.BindingContext>
    <VerticalStackLayout>
        <Label 
            Text="Prayer Card"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            FontSize="24"
            FontAttributes="Bold" />

        <Border Padding="20">
            <VerticalStackLayout Spacing="15" Margin="5">

                <HorizontalStackLayout Spacing="10">
                    <Label
                        VerticalOptions="Center"
                        WidthRequest="100"
                        Text="Title" />
                    <Entry
                        x:Name="TitleEntry"
                        Text="{Binding Title}"
                        VerticalOptions="Center"
                        Placeholder="Card Title" />
                </HorizontalStackLayout>

                <!-- Frequency Picker -->
                <HorizontalStackLayout Spacing="10">
                    <Label VerticalOptions="Center" WidthRequest="100" Text="Frequency" />
                    <Picker Title="Select Frequency"
                            ItemsSource="{Binding FrequencyOptions}"
                            SelectedItem="{Binding PrayerFrequency}"
                            HorizontalOptions="Start"
                            WidthRequest="200"
                            VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Allow Notifications -->
                <HorizontalStackLayout Spacing="10">
                    <Label VerticalOptions="Center" WidthRequest="100" Text="Reminders" />
                    <Switch IsToggled="{Binding CanNotify}"
                            OnColor="{StaticResource Secondary}"
                            VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Is Answered -->
                <HorizontalStackLayout Spacing="10">
                    <Label VerticalOptions="Center" WidthRequest="100" Text="Answered" />
                    <Switch IsToggled="{Binding IsAnswered}"
                            OnColor="{StaticResource Secondary}"
                            VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="4">
                    <Button 
                        StyleClass=""
                        HorizontalOptions="Start"
                        Command="{Binding DeleteCommand}"
                        Text="Delete" />
                    <Button 
                        StyleClass=""
                        Grid.Column="1"
                        HorizontalOptions="End"
                        Command="{Binding SaveCommand}"
                        Text="Save" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
