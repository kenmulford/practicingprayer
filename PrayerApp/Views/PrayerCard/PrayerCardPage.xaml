<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardPage"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:DataType="viewModels:PrayerCardViewModel"
             Title="Prayer Card"
             SafeAreaEdges="Container">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save"
                     Command="{Binding SaveCommand}"
                     SemanticProperties.Hint="Save prayer card changes"
                     x:DataType="viewModels:PrayerCardViewModel" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="12,8" Spacing="16">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackgroundTapped" />
                </VerticalStackLayout.GestureRecognizers>

                <Border Style="{StaticResource PrayerCardBorder}" Padding="16">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Title" Style="{StaticResource FormLabel}" />
                        <Entry x:Name="TitleEntry"
                               Text="{Binding Title}"
                               AutomationId="Card_Entry_Title"
                               IsReadOnly="{Binding IsSystem}"
                               HorizontalOptions="Fill"
                               Placeholder="Card title"
                               SemanticProperties.Hint="Name or topic for this prayer card" />

                        <!-- Collection picker (hidden for system cards) -->
                        <VerticalStackLayout Spacing="4"
                                             IsVisible="{Binding IsSystem, Converter={StaticResource InverseBool}}">
                            <Label Text="Collection" Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource PickerField}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Picker ItemsSource="{Binding AvailableBoxes}"
                                            SelectedItem="{Binding SelectedBox}"
                                            AutomationId="Card_Picker_Box"
                                            SemanticProperties.Hint="Choose which collection this card belongs to"
                                            HorizontalOptions="Fill" />
                                    <Label Style="{StaticResource PickerIndicator}" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <BoxView Style="{StaticResource DividerLine}" Margin="0,8,0,0" />

                        <!-- Delete Button — Save is in the navbar, Share is on the expanded card view -->
                        <Button Text="Delete"
                                AutomationId="Card_Btn_Delete"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DeleteCommand}"
                                IsVisible="{Binding CanDelete}"
                                HorizontalOptions="Fill" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — NameCard step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameCard"
            HeadlineText="Give it a name — a person, a topic, your church"
            SubText="Then tap Save." />

    </Grid>
</ContentPage>
