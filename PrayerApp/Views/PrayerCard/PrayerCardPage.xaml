<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardPage"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:DataType="viewModels:PrayerCardViewModel"
             Title="Prayer Card">
    <ContentPage.BindingContext>
        <viewModels:PrayerCardViewModel />
    </ContentPage.BindingContext>
    <VerticalStackLayout>
        <VerticalStackLayout Grid.Row="0" Padding="24">
        <Label 
            Text="Prayer Card"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            Style="{StaticResource CardTitle}"
            FontSize="24" />

        <Border Padding="20">
            <VerticalStackLayout Spacing="15" Margin="5">
                <Label Text="Title" 
                       Style="{StaticResource FormLabel}" />

                <Entry
                    x:Name="TitleEntry"
                    Text="{Binding Title}"
                    HorizontalOptions="Fill"
                    Placeholder="Card Title"
                    SemanticProperties.Hint="Name or topic for this prayer card" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="4">
                    <Button 
                        StyleClass=""
                        HorizontalOptions="Start"
                        Command="{Binding DeleteCommand}"
                        Text="Delete" />
                    <Button 
                        StyleClass=""
                        Grid.Column="1"
                        HorizontalOptions="End"
                        Command="{Binding SaveCommand}"
                        Text="Save" />
                </Grid>
            </VerticalStackLayout>
        </Border>
        </VerticalStackLayout>

        <!-- Onboarding coaching banner — NameCard step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameCard"
            HeadlineText="Give it a name — a person, a topic, your church"
            SubText="Then tap Save." />

    </VerticalStackLayout>
</ContentPage>
