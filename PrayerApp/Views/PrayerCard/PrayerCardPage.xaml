<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardPage"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:DataType="viewModels:PrayerCardViewModel"
             Title="Prayer Card">
    <ContentPage.BindingContext>
        <viewModels:PrayerCardViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="12,8" Spacing="16">

                <Border Style="{StaticResource PrayerCardBorder}" Padding="16">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Title" Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource InputBorder}" Padding="10,0">
                            <Entry x:Name="TitleEntry"
                                   Text="{Binding Title}"
                                   HorizontalOptions="Fill"
                                   Placeholder="Card title"
                                   SemanticProperties.Hint="Name or topic for this prayer card" />
                        </Border>

                        <BoxView Style="{StaticResource DividerLine}" Margin="0,8,0,0" />

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="Delete"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding DeleteCommand}"
                                    HorizontalOptions="Fill" />
                            <Button Grid.Column="1"
                                    Text="Save"
                                    Command="{Binding SaveCommand}"
                                    HorizontalOptions="Fill" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — NameCard step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameCard"
            HeadlineText="Give it a name — a person, a topic, your church"
            SubText="Then tap Save." />

    </Grid>
</ContentPage>
