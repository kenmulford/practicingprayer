<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             xmlns:shared="clr-namespace:PrayerApp.Views.Shared"
             xmlns:behaviors="clr-namespace:PrayerApp.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardsPage"
             x:DataType="viewModels:PrayerCardsViewModel"
             SafeAreaEdges="Container">
    <ContentPage.ToolbarItems>
        <!-- Single overflow button opens CardsOverflowPopup (Add Card, Manage Collections,
             Select Cards). Replaces the prior 3-Primary / iOS-Secondary split: the iOS
             UIMenu was unreadable in dark mode, and a unified MAUI-controlled popup gives
             full theming + a11y. In multi-select mode, the button mutates in place to a
             Cancel X (AutomationId switches to "Select" to match existing UITest callers). -->
        <ToolbarItem Text="More" AutomationId="More"
                     IconImageSource="{AppThemeBinding Light=ellipsis_vertical_solid_full.png, Dark=ellipsis_vertical_solid_full_dark.png}"
                     SemanticProperties.Description="More actions"
                     SemanticProperties.Hint="Opens a menu with Add Card, Manage Collections, and Select"
                     Clicked="OnOverflowTapped"
                     Order="Primary" Priority="0" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <!-- Slice 6c real (PERF-10): Lazy-construct the expanded card subtree.
             Deferring the chips + prayer list + add-prayer button out of the cell
             DataTemplate cuts platform inflation cost for collapsed cells (cold load
             and tab-switch return), where ~80% of the cell's visual tree is hidden
             but otherwise still measured/arranged. Code-behind realizes this template
             into the cell's <ContentView x:Name="ExpandedSubtreeHost"> on first
             IsExpanded=True (see OnCardBorderLoaded). Content is preserved across
             cell recycling — bindings re-resolve against the new BindingContext. -->
        <DataTemplate x:Key="CardExpandedSubtreeTemplate" x:DataType="viewModels:PrayerCardViewModel">
            <VerticalStackLayout Spacing="0">

                <HorizontalStackLayout
                    AutomationId="Cards_ActionChips"
                    IsVisible="{Binding ShowActionChips}"
                    Spacing="8"
                    Padding="12,4,12,8">

                    <!-- ★ Favorite — gold background when active, default when not -->
                    <Border Style="{StaticResource ActionChip}"
                            AutomationId="Cards_Btn_Favorite"
                            SemanticProperties.Description="Toggle favorite">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsFavorite}"
                                         Value="True">
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light={StaticResource ChipFavoritedBgLight}, Dark={StaticResource ChipFavoritedBgDark}}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="4">
                            <Image Source="star_solid_full.png" HeightRequest="14" WidthRequest="14"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   VerticalOptions="Center">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                        Light={StaticResource WarmGold},
                                        Dark={StaticResource WarmGoldDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label Text="{Binding FavoriteLabel}"
                                   FontSize="12"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource Tertiary},
                                       Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Share (disabled when card has 0 active prayers) -->
                    <Border Style="{StaticResource ActionChip}"
                            AutomationId="Cards_Btn_Share"
                            SemanticProperties.Description="Share card">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding CanShare}"
                                         Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="InputTransparent" Value="True" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShareCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="4">
                            <Image Source="share_from_square_solid_full.png" HeightRequest="14" WidthRequest="14"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   VerticalOptions="Center">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                        Light={StaticResource Primary},
                                        Dark={StaticResource PrimaryDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label Text="Share" FontSize="12"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource Tertiary},
                                       Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Edit -->
                    <Border Style="{StaticResource ActionChip}"
                            AutomationId="Cards_Btn_Edit"
                            SemanticProperties.Description="Edit card">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCardCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="4">
                            <Image Source="pen_to_square_solid_full.png" HeightRequest="14" WidthRequest="14"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   VerticalOptions="Center">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                        Light={StaticResource Primary},
                                        Dark={StaticResource PrimaryDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label Text="Edit" FontSize="12"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource Tertiary},
                                       Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Delete (danger styling) -->
                    <Border Style="{StaticResource ActionChip}"
                            AutomationId="Cards_Btn_Delete"
                            SemanticProperties.Description="Delete card"
                            BackgroundColor="{AppThemeBinding
                                Light={StaticResource ChipDangerBgLight},
                                Dark={StaticResource ChipDangerBgDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="4">
                            <Image Source="trash_can_solid_full.png" HeightRequest="14" WidthRequest="14"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   VerticalOptions="Center">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                        Light={StaticResource DangerRed},
                                        Dark={StaticResource DangerRedDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label Text="Delete" FontSize="12"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding
                                       Light={StaticResource DangerRed},
                                       Dark={StaticResource DangerRedDark}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>

                <!-- Prayer requests (BindableLayout — avoids nested CollectionView Android bug) -->
                <Label
                    Text="Prayers"
                    Style="{StaticResource PickerSectionHeader}"
                    IsVisible="{Binding IsExpanded}"
                    Margin="4,8,0,4"
                    AutomationProperties.IsInAccessibleTree="False" />
                <!-- Issue #33 P2: prayer rows sit directly on the expanded card's
                     CardExpandedLight/Dark background; PickerInsetSeparator delineates
                     rows. 8pt horizontal margin keeps rows inset from the card edge. -->
                <VerticalStackLayout
                    Spacing="0"
                    IsVisible="{Binding IsExpanded}"
                    Margin="8,0,8,0"
                    BindableLayout.ItemsSource="{Binding Prayers}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:PrayerRequestDetailViewModel">
                            <VerticalStackLayout Spacing="0">
                                <Border Style="{StaticResource PrayerRow}"
                                        SemanticProperties.Description="{Binding AccessibleSummary}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectPrayerCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding Title}"
                                            FontSize="16"
                                            AutomationProperties.IsInAccessibleTree="False"
                                            TextColor="{Binding IsAnswered, Converter={StaticResource BoolToMutedColor}}"
                                            TextDecorations="{Binding IsAnswered, Converter={StaticResource BoolToTextDecoration}}"
                                            VerticalOptions="Center" />
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding AnsweredAtDisplay}"
                                            Style="{StaticResource SuccessBadge}"
                                            IsVisible="{Binding IsAnswered}"
                                            VerticalOptions="Start"
                                            Margin="6,0,0,0"
                                            AutomationProperties.IsInAccessibleTree="False" />
                                    </Grid>
                                </Border>
                                <BoxView Style="{StaticResource PickerInsetSeparator}"
                                         AutomationProperties.IsInAccessibleTree="False" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button
                    Text="+ Add prayer ›"
                    Command="{Binding AddPrayerCommand}"
                    IsVisible="{Binding IsExpanded}"
                    AutomationId="Cards_Btn_AddPrayer"
                    SemanticProperties.Hint="Add a new prayer request to this card"
                    FontSize="17"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    BackgroundColor="Transparent"
                    FontAttributes="Bold"
                    Padding="16,8,12,10"
                    BorderWidth="0"
                    HorizontalOptions="Center" />

            </VerticalStackLayout>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <!-- Search -->
        <SearchBar x:Name="searchBar" Grid.Row="0"
                   Text="{Binding SearchText}"
                   AutomationId="Cards_Search"
                   Placeholder="Search cards..."
                   SearchButtonPressed="OnSearchButtonPressed"
                   SemanticProperties.Hint="Search prayer cards by name"
                   BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=Transparent}" />

        <!-- Tag filter chips -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    IsVisible="{Binding HasTags}"
                    HorizontalScrollBarVisibility="Never"
                    Margin="12,0">
            <HorizontalStackLayout
                BindableLayout.ItemsSource="{Binding AvailableTags}"
                Spacing="6"
                Padding="0,2,0,6">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TagFilterChipViewModel">
                        <Border Padding="10,4"
                                StrokeThickness="1.5"
                                SemanticProperties.Description="{Binding AccessibleDescription}"
                                SemanticProperties.Hint="Double tap to toggle filter">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                    <Setter Property="Stroke"          Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=Transparent, Dark=Transparent}" />
                                    <Setter Property="Stroke"          Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding Tag.Name}"
                                   FontSize="12"
                                   VerticalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Collections education banner — dismissed permanently via ✕ button -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowCollectionsBanner}"
                AutomationId="Cards_Banner_Collections"
                BackgroundColor="{AppThemeBinding Light={StaticResource OverdueLight}, Dark={StaticResource OverdueDark}}"
                StrokeThickness="0"
                Padding="14,10"
                Margin="12,4,12,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <Label Text="We've added Collections to help you organize your cards. Tap 'Collections' above to get started."
                       FontSize="13"
                       LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextSecondaryDark}}"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="✕"
                        AutomationId="Cards_Btn_DismissBanner"
                        Command="{Binding DismissCollectionsBannerCommand}"
                        SemanticProperties.Description="Dismiss collections tip"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}"
                        FontSize="14"
                        Padding="4"
                        BorderWidth="0"
                        WidthRequest="32"
                        HeightRequest="32"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <CollectionView
            Grid.Row="3"
            x:Name="cardCollection"
            AutomationId="Cards_List_Cards"
            AutomationProperties.IsInAccessibleTree="false"
            IsGrouped="True"
            ItemsSource="{Binding BoxSections}"
            ItemSizingStrategy="MeasureAllItems"
            Margin="12,8"
            SelectionMode="None">
        <!-- BUG-55 fix: Empty hint lives OUTSIDE the CollectionView so it never
             replaces group headers. Grouped CollectionView's built-in EmptyView
             hides group headers when all groups have 0 items, which prevents
             tapping section headers to re-expand collapsed collections. -->
        <CollectionView.GroupHeaderTemplate>
            <DataTemplate x:DataType="viewModels:BoxSectionViewModel">
                <VerticalStackLayout
                    AutomationId="Cards_Section_Header"
                    SemanticProperties.Description="{Binding Name}"
                    SemanticProperties.Hint="Double tap to expand or collapse section">
                    <!-- BUG-59: Dim headers during multi-select so focus stays on cards -->
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsMultiSelectMode}" Value="True">
                            <Setter Property="Opacity" Value="0.4" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                    <Grid ColumnDefinitions="Auto,*" Padding="4,14,4,8">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSectionHeaderTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="{Binding IsExpanded, Converter={StaticResource BoolToTriangle}}"
                               FontSize="11"
                               AutomationProperties.IsInAccessibleTree="False"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}"
                               VerticalOptions="Center"
                               Margin="0,0,6,0" />
                        <Label Grid.Column="1"
                               Text="{Binding HeaderText}"
                               Style="{StaticResource CardsSectionHeader}"
                               AutomationProperties.IsInAccessibleTree="False" />
                    </Grid>
                    <BoxView Style="{StaticResource DividerLine}" Margin="4,0"
                             AutomationProperties.IsInAccessibleTree="False" />
                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>
        <!-- Section footer: closing divider when expanded (visual bracket),
             plus "No cards yet" hint when expanded + empty.
             HeightRequest="0" collapses the footer entirely for collapsed sections
             so it doesn't contribute spacing between collapsed section headers (BUG-56). -->
        <CollectionView.GroupFooterTemplate>
            <DataTemplate x:DataType="viewModels:BoxSectionViewModel">
                <VerticalStackLayout HeightRequest="0" Spacing="0">
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="HeightRequest" Value="-1" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                    <!-- Empty-section hint (only when expanded + 0 cards) -->
                    <Label Text="No cards yet — move or create cards to add them here"
                           IsVisible="False"
                           HeightRequest="0"
                           Style="{StaticResource MutedText}"
                           Margin="0"
                           FontSize="13">
                        <Label.Triggers>
                            <MultiTrigger TargetType="Label">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsExpanded}" Value="True" />
                                    <BindingCondition Binding="{Binding CardCount}" Value="0" />
                                </MultiTrigger.Conditions>
                                <Setter Property="IsVisible" Value="True" />
                                <Setter Property="HeightRequest" Value="-1" />
                                <Setter Property="Margin" Value="46,4,16,12" />
                            </MultiTrigger>
                        </Label.Triggers>
                    </Label>
                    <!-- Closing divider (visible whenever expanded) -->
                    <BoxView Style="{StaticResource DividerLine}"
                             Margin="4,8,4,0"
                             IsVisible="{Binding IsExpanded}" />
                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.GroupFooterTemplate>
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:PrayerCardViewModel">

                <!-- Inter-cell separator (issue #33 P1); hidden when expanded so the lifted-card shadow reads cleanly.
                     Single Grid combines multi-select shifter columns (Auto,*) with row 1 separator slot —
                     keeps the cell-template container chain at dev-baseline depth (no wrapper Grid). -->
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,Auto">
                    <!-- Check slot (outside the card). Aligned with header row center via Margin top.
                         Source swaps based on per-card IsMultiSelected; tint reinforces state.
                         IsInAccessibleTree=False — selection state is announced via the header's
                         AccessibleCardHeader description (see ViewModel). -->
                    <Image
                        Grid.Column="0"
                        Source="circle_regular_full.png"
                        HeightRequest="22"
                        WidthRequest="22"
                        Margin="0,10,10,0"
                        VerticalOptions="Start"
                        IsVisible="{Binding IsMultiSelectMode}"
                        AutomationProperties.IsInAccessibleTree="False">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCheckCircleTapped" />
                        </Image.GestureRecognizers>
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}" />
                        </Image.Behaviors>
                        <Image.Triggers>
                            <!-- When the card is expanded, the Border gains Margin="0,8" — push the
                                 check down by the same amount so it stays aligned with the header row. -->
                            <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Margin" Value="0,18,10,0" />
                            </DataTrigger>
                            <DataTrigger TargetType="Image" Binding="{Binding IsMultiSelected}" Value="True">
                                <Setter Property="Source" Value="circle_check_solid_full.png" />
                            </DataTrigger>
                        </Image.Triggers>
                    </Image>

                    <Border Grid.Column="1"
                            Style="{StaticResource PrayerCardBorder}"
                            Padding="0"
                            Margin="{StaticResource CardContentLeftInsetMargin}"
                            behaviors:VisualStateBindingBehavior.Source="{Binding CardVisualState}"
                            Loaded="OnCardBorderLoaded">
                        <!-- Inline Margin default matches the collapsed state so the
                             IsExpanded DataTrigger below is the sole writer on transition.
                             Every Margin write invalidates parent layout, which on Android
                             schedules the next measure pass, which loads the next cell,
                             etc. — keeping the default aligned with collapsed avoids a
                             trigger-fire cascade on first realization (PERF-10, 2026-04-26). -->
                        <Border.Triggers>
                            <!-- Expanded cards get a subtle "lifted paper" shadow. iOS Shadow rendering
                                 can be uneven — keep it soft so absence isn't visually jarring. -->
                            <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Margin" Value="0,8,0,8" />
                                <Setter Property="Shadow">
                                    <Shadow Brush="Black" Opacity="0.15" Radius="8" Offset="0,2" />
                                </Setter>
                            </DataTrigger>
                            <!-- Warm tint on expanded non-system cards. System cards already set their own
                                 BackgroundColor (below) — MultiTrigger with IsSystem=False avoids override. -->
                            <MultiTrigger TargetType="Border">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsExpanded}" Value="True" />
                                    <BindingCondition Binding="{Binding IsSystem}"   Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding
                                    Light={StaticResource CardExpandedLight}, Dark={StaticResource CardExpandedDark}}" />
                            </MultiTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSystem}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding
                                    Light={StaticResource SystemCardLight}, Dark={StaticResource SystemCardDark}}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <!-- BUG-60: Long-press wired in code-behind — iOS via OnCardBorderLoaded, Android via OnCardHeaderLoaded -->

                        <VerticalStackLayout Spacing="0">

                            <!-- Card header: title + system badge + imported icon + count badge + favorite star -->
                            <!-- A11Y: Description on the Grid (single tappable unit), not the Label (avoids double-read) -->
                            <Grid
                                Padding="12,10"
                                ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                                SemanticProperties.Description="{Binding AccessibleCardHeader}"
                                SemanticProperties.Hint="Double tap to expand or collapse"
                                Loaded="OnCardHeaderLoaded">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCardHeaderTapped" />
                                </Grid.GestureRecognizers>
                                <Label
                                    Grid.Column="0"
                                    Text="{Binding Title}"
                                    Style="{StaticResource CardTitle}"
                                    AutomationProperties.IsInAccessibleTree="False"
                                    TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                                    VerticalOptions="Center" />
                                <!-- System badge -->
                                <Label
                                    Grid.Column="1"
                                    Text="System"
                                    FontSize="10"
                                    IsVisible="{Binding IsSystem}"
                                    AutomationProperties.IsInAccessibleTree="False"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}"
                                    VerticalOptions="Center"
                                    Margin="6,0,6,0" />
                                <!-- Imported icon (shared content) -->
                                <Image
                                    Grid.Column="2"
                                    Source="imported.png"
                                    HeightRequest="18"
                                    WidthRequest="18"
                                    IsVisible="{Binding IsImported}"
                                    VerticalOptions="Center"
                                    Margin="4,0"
                                    AutomationProperties.IsInAccessibleTree="False">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                    </Image.Behaviors>
                                </Image>
                                <!-- Active prayer count — parenthetical muted text on collapsed cards (issue #33 P3).
                                     HasAnyPrayer hides the Label entirely when count is zero or the card is expanded. -->
                                <Label
                                    Grid.Column="3"
                                    Style="{StaticResource MutedText}"
                                    Text="{Binding ActivePrayerCount, StringFormat='({0})'}"
                                    IsVisible="{Binding HasAnyPrayer}"
                                    FontSize="14"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"
                                    Margin="0,0,8,0"
                                    AutomationProperties.IsInAccessibleTree="False" />
                                <Label
                                    Grid.Column="4"
                                    Text="★"
                                    FontSize="16"
                                    AutomationProperties.IsInAccessibleTree="False"
                                    TextColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}"
                                    IsVisible="{Binding IsFavorite}"
                                    VerticalOptions="Center"
                                    Margin="8,0,0,0" />
                            </Grid>

                        <BoxView Style="{StaticResource DividerLine}"
                                 IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <!-- Slice 6c real (PERF-10): Lazy-realized expanded subtree.
                             Content (chips + prayer list + Add Prayer button) is set
                             programmatically by OnCardBorderLoaded.Rebind on first
                             IsExpanded=True. Until then this ContentView holds null
                             Content and contributes ~zero cost to the cell's measure
                             pass. Lifetime is the cell's recycle window — Content is
                             retained across BindingContext swaps so the cost amortizes
                             on rapid scroll. See ContentPage.Resources/CardExpandedSubtreeTemplate. -->
                        <ContentView x:Name="ExpandedSubtreeHost" />

                        </VerticalStackLayout>
                    </Border>
                    <!-- Inter-cell separator at row 1; spans both Grid columns so the line crosses the
                         multi-select gutter when collapsed. The Margin's left inset still pulls the visible
                         line back from the cell edge to align with card content. -->
                    <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                             Style="{StaticResource PickerInsetSeparator}"
                             Margin="{StaticResource CardContentLeftInsetMargin}">
                        <BoxView.Triggers>
                            <DataTrigger TargetType="BoxView" Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </BoxView.Triggers>
                    </BoxView>
                </Grid>

            </DataTemplate>
        </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- BUG-55: External empty hint — InputTransparent so collapsed group headers
             remain tappable beneath this overlay. Only visible when truly empty. -->
        <Label Grid.Row="3"
               IsVisible="False"
               InputTransparent="True"
               Text="You need to create your first prayer card! Prayer cards are meant to work like a 3x5 card — the card is a person's name, a topic, anything really. Once you create it, add one or many prayer requests to the card! Get started above by tapping 'Add Card'."
               Style="{StaticResource MutedText}"
               HorizontalTextAlignment="Center"
               Margin="36,32">
            <Label.Triggers>
                <MultiTrigger TargetType="Label">
                    <MultiTrigger.Conditions>
                        <BindingCondition Binding="{Binding HasNoSections}" Value="True" />
                        <BindingCondition Binding="{Binding IsLoading}" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="IsVisible" Value="True" />
                </MultiTrigger>
            </Label.Triggers>
        </Label>

        <!-- CreateCard step banner -->
        <onboarding:OnboardingBanner
            Grid.Row="4"
            ExpectedStep="CreateCard"
            HeadlineText="Tap 'Add Card' to create your first prayer card"
            SubText="Give it a name — a person, a topic, or a place." />

        <!-- AddRequest step banner -->
        <onboarding:OnboardingBanner
            Grid.Row="5"
            ExpectedStep="AddRequest"
            HeadlineText="Great! Now tap the name of your new card to expand it; then tap '+ Add prayer'"
            SubText="Add your first prayer request to this card." />

        <!-- BUG-59: Multi-select toolbar overlays search/tag rows at top (visible during long-press) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                ZIndex="10"
                VerticalOptions="Fill"
                AutomationId="Cards_Bar_MultiSelect"
                IsVisible="{Binding IsMultiSelectMode}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                StrokeThickness="0"
                Padding="16,10">
            <!-- Cancel is on the toolbar (Cards_Btn_Select mutates to X) — bar shows count + Move to… only. -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding SelectedCountText}"
                       TextColor="White"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Move to…"
                        AutomationId="Cards_Btn_MoveToBox"
                        Command="{Binding MoveSelectedCommand}"
                        SemanticProperties.Hint="Move selected cards to a collection"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="14"
                        FontAttributes="Bold"
                        Padding="8,4" />
            </Grid>
        </Border>

        <!-- Slice 6g: bind to IsBusyOverall (= IsLoading || IsAwaitingSavedCard)
             so the overlay persists across the post-save SyncAsync→ConsumePendingSavedAsync
             →ScrollTo window even after SyncAsync's finally has flipped IsLoading off. -->
        <shared:LoadingOverlay Grid.Row="0" Grid.RowSpan="7" IsLoading="{Binding IsBusyOverall}" />

    </Grid>
</ContentPage>

