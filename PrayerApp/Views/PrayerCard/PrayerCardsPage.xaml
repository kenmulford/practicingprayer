<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardsPage"
             NavigatedTo="ContentPage_NavigatedTo"
             x:DataType="viewModels:PrayerCardsViewModel">
    <ContentPage.BindingContext>
        <viewModels:PrayerCardsViewModel />
    </ContentPage.BindingContext>
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add Card" Command="{Binding NewCommand}" />
    </ContentPage.ToolbarItems>

    <CollectionView
        x:Name="cardCollection"
        ItemsSource="{Binding AllPrayerCards}"
        Margin="12,8"
        SelectionMode="None">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:PrayerCardViewModel">

                <!-- Card wrapper with swipe for Favorite/Edit/Delete -->
                <SwipeView Threshold="80">
                    <SwipeView.LeftItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem
                                BackgroundColor="{StaticResource WarmGold}"
                                Command="{Binding ToggleFavoriteCommand}"
                                Text="★" />
                            <SwipeItem
                                BackgroundColor="{StaticResource Primary}"
                                Command="{Binding SelectCardCommand}"
                                Text="Edit" />
                        </SwipeItems>
                    </SwipeView.LeftItems>
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem
                                BackgroundColor="{StaticResource DangerRed}"
                                IconImageSource="trash_can_solid_full.png"
                                Command="{Binding DeleteCommand}"
                                Text="Delete" />
                        </SwipeItems>
                    </SwipeView.RightItems>

                    <!-- 3×5 card body -->
                    <Border Style="{StaticResource PrayerCardBorder}"
                            Padding="0">

                        <VerticalStackLayout Spacing="0">

                            <!-- Card header: title + favorite star -->
                            <Grid
                                Padding="12,10"
                                ColumnDefinitions="*,Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandedCommand}" />
                                </Grid.GestureRecognizers>
                                <Label
                                    Text="{Binding Title}"
                                    Style="{StaticResource CardTitle}"
                                    TextColor="{StaticResource Tertiary}"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    Text="★"
                                    FontSize="16"
                                    TextColor="{StaticResource WarmGold}"
                                    IsVisible="{Binding IsFavorite}"
                                    VerticalOptions="Center"
                                    Margin="8,0,0,0" />
                            </Grid>

                            <!-- Horizontal rule -->


                            <BoxView Style="{StaticResource DividerLine}" />

                            <!-- Prayer requests (BindableLayout — avoids nested CollectionView Android bug) -->
                            <VerticalStackLayout
                                IsVisible="{Binding IsExpanded}"
                                Spacing="0"
                                BindableLayout.ItemsSource="{Binding Prayers}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:PrayerRequestDetailViewModel">
                                        <SwipeView Threshold="80">
                                            <SwipeView.LeftItems>
                                                <SwipeItems Mode="Reveal">
                                                    <SwipeItem
                                                        BackgroundColor="{StaticResource Primary}"
                                                        Command="{Binding EditPrayerCommand}"
                                                        Text="Edit" />
                                                </SwipeItems>
                                            </SwipeView.LeftItems>
                                            <SwipeView.RightItems>
                                                <SwipeItems Mode="Reveal">
                                                    <SwipeItem
                                                        BackgroundColor="{StaticResource DangerRed}"
                                                        Command="{Binding DeleteCommand}"
                                                        Text="Delete" />
                                                </SwipeItems>
                                            </SwipeView.RightItems>

                                            <!-- Prayer row -->
                                            <Grid
                                                Padding="16,8,12,8"
                                                ColumnDefinitions="*,Auto">
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding SelectPrayerCommand}" />
                                                </Grid.GestureRecognizers>
                                                <Label
                                                    Text="{Binding Title}"
                                                    FontSize="15"
                                                    TextColor="{Binding IsAnswered, Converter={StaticResource BoolToMutedColor}}"
                                                    TextDecorations="{Binding IsAnswered, Converter={StaticResource BoolToTextDecoration}}"
                                                    VerticalOptions="Center" />
                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding AnsweredAtDisplay}"
                                                    Style="{StaticResource SuccessBadge}"
                                                    IsVisible="{Binding IsAnswered}"
                                                    VerticalOptions="Start"
                                                    Margin="6,0,0,0" />
                                            </Grid>
                                        </SwipeView>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!-- + Add prayer row (only shown when expanded) -->
                            <Grid
                                Padding="16,8,12,10"
                                IsVisible="{Binding IsExpanded}">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddPrayerCommand}" />
                                </Grid.GestureRecognizers>
                                <Label
                                    Text="+ Add prayer"
                                    FontSize="14"
                                    TextColor="{StaticResource Primary}"
                                    FontAttributes="Italic" />
                            </Grid>

                        </VerticalStackLayout>
                    </Border>
                </SwipeView>

            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>

