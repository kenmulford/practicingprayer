<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardsPage"
             x:DataType="viewModels:PrayerCardsViewModel">
    <ContentPage.BindingContext>
        <viewModels:PrayerCardsViewModel />
    </ContentPage.BindingContext>
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add Card" Command="{Binding NewCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto,Auto">

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <CollectionView
            Grid.Row="0"
            x:Name="cardCollection"
            ItemsSource="{Binding AllPrayerCards}"
            Margin="12,8"
            SelectionMode="None">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:PrayerCardViewModel">

                <!-- Card wrapper with swipe for Favorite/Edit/Delete -->
                <SwipeView Threshold="80">
                    <SwipeView.LeftItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem
                                BackgroundColor="{AppThemeBinding Light={StaticResource ButtonSecondaryLight}, Dark={StaticResource ButtonSecondaryDark}}"
                                Command="{Binding ToggleFavoriteCommand}"
                                IsVisible="{Binding IsSystem, Converter={StaticResource InverseBool}}"
                                SemanticProperties.Description="Toggle favorite"
                                Text="★" />
                            <SwipeItem
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                                Command="{Binding SelectCardCommand}"
                                IsVisible="{Binding IsSystem, Converter={StaticResource InverseBool}}"
                                SemanticProperties.Description="Edit card"
                                Text="Edit" />
                        </SwipeItems>
                    </SwipeView.LeftItems>
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem
                                BackgroundColor="{AppThemeBinding Light={StaticResource DangerRed}, Dark={StaticResource DangerRed}}"
                                IconImageSource="trash_can_solid_full.png"
                                Command="{Binding DeleteCommand}"
                                IsVisible="{Binding IsSystem, Converter={StaticResource InverseBool}}"
                                SemanticProperties.Description="Delete card"
                                Text="Delete" />
                        </SwipeItems>
                    </SwipeView.RightItems>

                    <!-- 3×5 card body -->
                    <Border Style="{StaticResource PrayerCardBorder}"
                            Padding="0">

                        <VerticalStackLayout Spacing="0">

                            <!-- Card header: title + badge + favorite star -->
                            <Grid
                                Padding="12,10"
                                ColumnDefinitions="*,Auto,Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandedCommand}" />
                                </Grid.GestureRecognizers>
                                <Label
                                    Text="{Binding Title}"
                                    Style="{StaticResource CardTitle}"
                                    SemanticProperties.Hint="Double tap to expand or collapse. Swipe left to delete, right to edit or favorite"
                                    TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                                    VerticalOptions="Center" />
                                <!-- Active prayer count badge (collapsed only) -->
                                <Border
                                    Grid.Column="1"
                                    IsVisible="{Binding ShowBadge}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    Padding="6,2"
                                    HeightRequest="20"
                                    MinimumWidthRequest="20"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"
                                    Margin="0,0,8,0"
                                    AutomationProperties.IsInAccessibleTree="false">
                                    <Label
                                        Text="{Binding ActivePrayerCount}"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Border>
                                <Label
                                    Grid.Column="2"
                                    Text="★"
                                    FontSize="16"
                                    SemanticProperties.Description="Favorited"
                                    TextColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}"
                                    IsVisible="{Binding IsFavorite}"
                                    VerticalOptions="Center"
                                    Margin="8,0,0,0" />
                            </Grid>

                            <!-- Horizontal rule -->


                            <BoxView Style="{StaticResource DividerLine}" />

                            <!-- Prayer requests (BindableLayout — avoids nested CollectionView Android bug) -->
                            <VerticalStackLayout
                                IsVisible="{Binding IsExpanded}"
                                Spacing="0"
                                BindableLayout.ItemsSource="{Binding Prayers}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:PrayerRequestDetailViewModel">
                                        <VerticalStackLayout Spacing="0">
                                            <SwipeView Threshold="80">
                                                <SwipeView.LeftItems>
                                                    <SwipeItems Mode="Reveal">
                                                        <SwipeItem
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                                                            Command="{Binding EditPrayerCommand}"
                                                            SemanticProperties.Description="Edit prayer"
                                                            Text="Edit" />
                                                    </SwipeItems>
                                                </SwipeView.LeftItems>
                                                <SwipeView.RightItems>
                                                    <SwipeItems Mode="Reveal">
                                                        <SwipeItem
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource DangerRed}, Dark={StaticResource DangerRed}}"
                                                            Command="{Binding DeleteCommand}"
                                                            SemanticProperties.Description="Delete prayer"
                                                            Text="Delete" />
                                                    </SwipeItems>
                                                </SwipeView.RightItems>

                                                <!-- Prayer row -->
                                                <Grid
                                                    Padding="16,8,12,8"
                                                    ColumnDefinitions="*,Auto">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding SelectPrayerCommand}" />
                                                    </Grid.GestureRecognizers>
                                                    <Label
                                                        Text="{Binding Title}"
                                                        FontSize="15"
                                                        SemanticProperties.Hint="Double tap to view. Swipe left to delete, right to edit"
                                                        TextColor="{Binding IsAnswered, Converter={StaticResource BoolToMutedColor}}"
                                                        TextDecorations="{Binding IsAnswered, Converter={StaticResource BoolToTextDecoration}}"
                                                        VerticalOptions="Center" />
                                                    <Label
                                                        Grid.Column="1"
                                                        Text="{Binding AnsweredAtDisplay}"
                                                        Style="{StaticResource SuccessBadge}"
                                                        IsVisible="{Binding IsAnswered}"
                                                        VerticalOptions="Start"
                                                        Margin="6,0,0,0" />
                                                </Grid>
                                            </SwipeView>
                                            <BoxView Style="{StaticResource DividerLine}" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <!-- + Add prayer row (only shown when expanded) -->
                            <Button
                                Text="+ Add prayer"
                                Command="{Binding AddPrayerCommand}"
                                IsVisible="{Binding IsExpanded}"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                BackgroundColor="Transparent"
                                FontAttributes="Italic"
                                Padding="16,8,12,10"
                                BorderWidth="0"
                                HorizontalOptions="Start" />

                        </VerticalStackLayout>
                    </Border>
                </SwipeView>

            </DataTemplate>
        </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- CreateCard step banner -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="CreateCard"
            HeadlineText="Tap 'Add Card' to create your first prayer card"
            SubText="Give it a name — a person, a topic, or a place." />

        <!-- AddRequest step banner -->
        <onboarding:OnboardingBanner
            Grid.Row="2"
            ExpectedStep="AddRequest"
            HeadlineText="Great! Now tap the name of your new card to expand it; then tap '+ Add prayer'"
            SubText="Add your first prayer request to this card." />

    </Grid>
</ContentPage>

