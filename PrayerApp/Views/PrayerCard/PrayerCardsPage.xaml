<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PrayerApp.Views.PrayerCard.PrayerCardsPage"
             x:DataType="viewModels:PrayerCardsViewModel"
             SafeAreaEdges="Container">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Collections" AutomationId="Cards_Btn_Collections"
                     SemanticProperties.Hint="Manage collections"
                     Clicked="OnCollectionsTapped"
                     Order="Primary" Priority="0" />
        <ToolbarItem Text="Add Card" Command="{Binding NewCommand}"
                     Order="Primary" Priority="1" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <!-- Search -->
        <SearchBar x:Name="searchBar" Grid.Row="0"
                   Text="{Binding SearchText}"
                   AutomationId="Cards_Search"
                   Placeholder="Search cards..."
                   SearchButtonPressed="OnSearchButtonPressed"
                   SemanticProperties.Hint="Search prayer cards by name"
                   BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=Transparent}" />

        <!-- Tag filter chips -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    IsVisible="{Binding HasTags}"
                    HorizontalScrollBarVisibility="Never"
                    Margin="12,0">
            <HorizontalStackLayout
                BindableLayout.ItemsSource="{Binding AvailableTags}"
                Spacing="6"
                Padding="0,2,0,6">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TagFilterChipViewModel">
                        <Border Padding="10,4"
                                StrokeThickness="1.5"
                                SemanticProperties.Hint="Double tap to toggle filter">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                    <Setter Property="Stroke"          Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=Transparent, Dark=Transparent}" />
                                    <Setter Property="Stroke"          Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{Binding Tag.Name}"
                                   FontSize="12"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Collections education banner — dismissed permanently via ✕ button -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowCollectionsBanner}"
                AutomationId="Cards_Banner_Collections"
                BackgroundColor="{AppThemeBinding Light={StaticResource OverdueLight}, Dark={StaticResource OverdueDark}}"
                StrokeThickness="0"
                Padding="14,10"
                Margin="12,4,12,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <Label Text="We've added Collections to help you organize your cards. Tap 'Collections' above to get started."
                       FontSize="13"
                       LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextSecondaryDark}}"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="✕"
                        AutomationId="Cards_Btn_DismissBanner"
                        Command="{Binding DismissCollectionsBannerCommand}"
                        SemanticProperties.Description="Dismiss collections tip"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}"
                        FontSize="14"
                        Padding="4"
                        BorderWidth="0"
                        WidthRequest="32"
                        HeightRequest="32"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <CollectionView
            Grid.Row="3"
            x:Name="cardCollection"
            AutomationId="Cards_List_Cards"
            AutomationProperties.IsInAccessibleTree="false"
            IsGrouped="True"
            ItemsSource="{Binding BoxSections}"
            ItemSizingStrategy="MeasureAllItems"
            Margin="12,8"
            SelectionMode="None">
        <!-- BUG-55 fix: Empty hint lives OUTSIDE the CollectionView so it never
             replaces group headers. Grouped CollectionView's built-in EmptyView
             hides group headers when all groups have 0 items, which prevents
             tapping section headers to re-expand collapsed collections. -->
        <CollectionView.GroupHeaderTemplate>
            <DataTemplate x:DataType="viewModels:BoxSectionViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Padding="4,12,4,6"
                      AutomationId="Cards_Section_Header"
                      SemanticProperties.Description="{Binding Name}"
                      SemanticProperties.Hint="Double tap to expand or collapse section">
                    <!-- BUG-59: Dim headers during multi-select so focus stays on cards -->
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding IsMultiSelectMode}" Value="True">
                            <Setter Property="Opacity" Value="0.4" />
                        </DataTrigger>
                    </Grid.Triggers>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" />
                    </Grid.GestureRecognizers>
                    <Label Text="{Binding IsExpanded, Converter={StaticResource BoolToTriangle}}"
                           FontSize="11"
                           AutomationProperties.IsInAccessibleTree="False"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}"
                           VerticalOptions="Center"
                           Margin="0,0,6,0" />
                    <Label Grid.Column="1"
                           Text="{Binding Name}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="2"
                           Text="{Binding CardCount}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource TextMutedDark}}"
                           VerticalOptions="Center" />
                </Grid>
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>
        <!-- BUG-56: Empty collection hint — only when expanded AND 0 cards.
             HeightRequest="0" collapses the footer entirely for non-empty/collapsed sections
             so it doesn't contribute spacing between collapsed section headers. -->
        <CollectionView.GroupFooterTemplate>
            <DataTemplate x:DataType="viewModels:BoxSectionViewModel">
                <Label Text="No cards yet — move or create cards to add them here"
                       IsVisible="False"
                       HeightRequest="0"
                       Style="{StaticResource MutedText}"
                       Margin="0"
                       FontSize="13">
                    <Label.Triggers>
                        <MultiTrigger TargetType="Label">
                            <MultiTrigger.Conditions>
                                <BindingCondition Binding="{Binding IsExpanded}" Value="True" />
                                <BindingCondition Binding="{Binding CardCount}" Value="0" />
                            </MultiTrigger.Conditions>
                            <Setter Property="IsVisible" Value="True" />
                            <Setter Property="HeightRequest" Value="-1" />
                            <Setter Property="Margin" Value="46,4,16,12" />
                        </MultiTrigger>
                    </Label.Triggers>
                </Label>
            </DataTemplate>
        </CollectionView.GroupFooterTemplate>
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:PrayerCardViewModel">

                <!-- Card body — inline action buttons replace SwipeView for reliability on iOS -->
                <!-- UX-32: Left indent reinforces nesting under section headers -->
                <Border Style="{StaticResource PrayerCardBorder}"
                        Padding="0"
                        Margin="14,0,0,0"
                        Loaded="OnCardBorderLoaded">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsHighlighted}" Value="True">
                            <Setter Property="Stroke" Value="{AppThemeBinding
                                Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                            <Setter Property="StrokeThickness" Value="2.5" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="Margin" Value="0,8" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsSystem}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding
                                Light={StaticResource SystemCardLight}, Dark={StaticResource SystemCardDark}}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsMultiSelected}" Value="True">
                            <Setter Property="Stroke" Value="{AppThemeBinding
                                Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                            <Setter Property="StrokeThickness" Value="2.5" />
                        </DataTrigger>
                    </Border.Triggers>
                    <!-- BUG-60: Long-press wired in code-behind — iOS via OnCardBorderLoaded, Android via OnCardHeaderLoaded -->

                    <VerticalStackLayout Spacing="0">

                        <!-- Card header: title + system badge + imported icon + count badge + favorite star -->
                        <!-- A11Y: Description on the Grid (single tappable unit), not the Label (avoids double-read) -->
                        <Grid
                            Padding="12,10"
                            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                            SemanticProperties.Description="{Binding AccessibleCardHeader}"
                            SemanticProperties.Hint="Double tap to expand or collapse"
                            Loaded="OnCardHeaderLoaded">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardHeaderTapped" />
                            </Grid.GestureRecognizers>
                            <Label
                                Text="{Binding Title}"
                                Style="{StaticResource CardTitle}"
                                AutomationProperties.IsInAccessibleTree="False"
                                TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                                VerticalOptions="Center" />
                            <!-- System badge -->
                            <Label
                                Grid.Column="1"
                                Text="System"
                                FontSize="10"
                                IsVisible="{Binding IsSystem}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}"
                                VerticalOptions="Center"
                                Margin="6,0,6,0" />
                            <!-- Imported icon (shared content) -->
                            <Image
                                Grid.Column="2"
                                Source="imported.png"
                                HeightRequest="18"
                                WidthRequest="18"
                                IsVisible="{Binding IsImported}"
                                VerticalOptions="Center"
                                Margin="4,0"
                                SemanticProperties.Description="Imported card">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <!-- Active prayer count badge (collapsed only) -->
                            <Border
                                Grid.Column="3"
                                IsVisible="{Binding ShowBadge}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="6,2"
                                HeightRequest="20"
                                MinimumWidthRequest="20"
                                VerticalOptions="Center"
                                HorizontalOptions="End"
                                Margin="0,0,8,0"
                                AutomationProperties.IsInAccessibleTree="false">
                                <Label
                                    Text="{Binding ActivePrayerCount}"
                                    FontSize="11"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                            <Label
                                Grid.Column="4"
                                Text="★"
                                FontSize="16"
                                SemanticProperties.Description="Favorited"
                                TextColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}"
                                IsVisible="{Binding IsFavorite}"
                                VerticalOptions="Center"
                                Margin="8,0,0,0" />
                        </Grid>

                        <BoxView Style="{StaticResource DividerLine}" />

                        <!-- Card action chips — visible when expanded, hidden for system cards -->
                        <HorizontalStackLayout
                            AutomationId="Cards_ActionChips"
                            IsVisible="{Binding ShowActionChips}"
                            Spacing="8"
                            Padding="12,4,12,8">

                            <!-- ★ Favorite — gold background when active, default when not -->
                            <Border Style="{StaticResource ActionChip}"
                                    AutomationId="Cards_Btn_Favorite"
                                    SemanticProperties.Description="Toggle favorite">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsFavorite}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource ChipFavoritedBgLight}, Dark={StaticResource ChipFavoritedBgDark}}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="4">
                                    <Image Source="star_solid_full.png" HeightRequest="14" WidthRequest="14"
                                           AutomationProperties.IsInAccessibleTree="False"
                                           VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                                Light={StaticResource WarmGold},
                                                Dark={StaticResource WarmGoldDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Label Text="{Binding FavoriteLabel}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding
                                               Light={StaticResource Tertiary},
                                               Dark={StaticResource TextPrimaryDark}}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Share (disabled when card has 0 active prayers) -->
                            <Border Style="{StaticResource ActionChip}"
                                    AutomationId="Cards_Btn_Share"
                                    SemanticProperties.Description="Share card">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding CanShare}"
                                                 Value="False">
                                        <Setter Property="Opacity" Value="0.4" />
                                        <Setter Property="InputTransparent" Value="True" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ShareCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="4">
                                    <Image Source="share_from_square_solid_full.png" HeightRequest="14" WidthRequest="14"
                                           AutomationProperties.IsInAccessibleTree="False"
                                           VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                                Light={StaticResource Primary},
                                                Dark={StaticResource PrimaryDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Label Text="Share" FontSize="12"
                                           TextColor="{AppThemeBinding
                                               Light={StaticResource Tertiary},
                                               Dark={StaticResource TextPrimaryDark}}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Edit -->
                            <Border Style="{StaticResource ActionChip}"
                                    AutomationId="Cards_Btn_Edit"
                                    SemanticProperties.Description="Edit card">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCardCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="4">
                                    <Image Source="pen_to_square_solid_full.png" HeightRequest="14" WidthRequest="14"
                                           AutomationProperties.IsInAccessibleTree="False"
                                           VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                                Light={StaticResource Primary},
                                                Dark={StaticResource PrimaryDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Label Text="Edit" FontSize="12"
                                           TextColor="{AppThemeBinding
                                               Light={StaticResource Tertiary},
                                               Dark={StaticResource TextPrimaryDark}}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Delete (danger styling) -->
                            <Border Style="{StaticResource ActionChip}"
                                    AutomationId="Cards_Btn_Delete"
                                    SemanticProperties.Description="Delete card"
                                    BackgroundColor="{AppThemeBinding
                                        Light={StaticResource ChipDangerBgLight},
                                        Dark={StaticResource ChipDangerBgDark}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="4">
                                    <Image Source="trash_can_solid_full.png" HeightRequest="14" WidthRequest="14"
                                           AutomationProperties.IsInAccessibleTree="False"
                                           VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding
                                                Light={StaticResource DangerRed},
                                                Dark={StaticResource DangerRedDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Label Text="Delete" FontSize="12"
                                           TextColor="{AppThemeBinding
                                               Light={StaticResource DangerRed},
                                               Dark={StaticResource DangerRedDark}}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Prayer requests (BindableLayout — avoids nested CollectionView Android bug) -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsExpanded}"
                            Spacing="0"
                            BindableLayout.ItemsSource="{Binding Prayers}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:PrayerRequestDetailViewModel">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid
                                            Padding="16,10,12,10"
                                            ColumnDefinitions="*,Auto,Auto">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectPrayerCommand}" />
                                            </Grid.GestureRecognizers>
                                            <Label
                                                Text="{Binding Title}"
                                                FontSize="16"
                                                SemanticProperties.Hint="Double tap to view"
                                                TextColor="{Binding IsAnswered, Converter={StaticResource BoolToMutedColor}}"
                                                TextDecorations="{Binding IsAnswered, Converter={StaticResource BoolToTextDecoration}}"
                                                VerticalOptions="Center" />
                                            <Image
                                                Grid.Column="1"
                                                Source="imported.png"
                                                HeightRequest="16"
                                                WidthRequest="16"
                                                IsVisible="{Binding IsImported}"
                                                VerticalOptions="Center"
                                                Margin="4,0"
                                                SemanticProperties.Description="Imported prayer">
                                                <Image.Behaviors>
                                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                                </Image.Behaviors>
                                            </Image>
                                            <Label
                                                Grid.Column="2"
                                                Text="{Binding AnsweredAtDisplay}"
                                                Style="{StaticResource SuccessBadge}"
                                                IsVisible="{Binding IsAnswered}"
                                                VerticalOptions="Start"
                                                Margin="6,0,0,0" />
                                        </Grid>
                                        <!-- Inline color binding — style-only AppThemeBinding
                                             doesn't reliably propagate to all BindableLayout children -->
                                        <BoxView Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource CardBorderDark}}"
                                                 Opacity="0.4"
                                                 HeightRequest="1"
                                                 HorizontalOptions="Fill"
                                                 AutomationProperties.IsInAccessibleTree="False" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- + Add prayer row (only shown when expanded) -->
                        <Button
                            Text="+ Add prayer ›"
                            Command="{Binding AddPrayerCommand}"
                            IsVisible="{Binding IsExpanded}"
                            AutomationId="Cards_Btn_AddPrayer"
                            SemanticProperties.Hint="Add a new prayer request to this card"
                            FontSize="14"
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            BackgroundColor="Transparent"
                            FontAttributes="Bold"
                            Padding="16,8,12,10"
                            BorderWidth="0"
                            HorizontalOptions="Start" />

                    </VerticalStackLayout>
                </Border>

            </DataTemplate>
        </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- BUG-55: External empty hint — InputTransparent so collapsed group headers
             remain tappable beneath this overlay. Only visible when truly empty. -->
        <Label Grid.Row="3"
               IsVisible="False"
               InputTransparent="True"
               Text="You need to create your first prayer card! Prayer cards are meant to work like a 3x5 card — the card is a person's name, a topic, anything really. Once you create it, add one or many prayer requests to the card! Get started above by tapping 'Add Card'."
               Style="{StaticResource MutedText}"
               HorizontalTextAlignment="Center"
               Margin="36,32">
            <Label.Triggers>
                <MultiTrigger TargetType="Label">
                    <MultiTrigger.Conditions>
                        <BindingCondition Binding="{Binding HasNoSections}" Value="True" />
                        <BindingCondition Binding="{Binding IsLoading}" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="IsVisible" Value="True" />
                </MultiTrigger>
            </Label.Triggers>
        </Label>

        <!-- CreateCard step banner -->
        <onboarding:OnboardingBanner
            Grid.Row="4"
            ExpectedStep="CreateCard"
            HeadlineText="Tap 'Add Card' to create your first prayer card"
            SubText="Give it a name — a person, a topic, or a place." />

        <!-- AddRequest step banner -->
        <onboarding:OnboardingBanner
            Grid.Row="5"
            ExpectedStep="AddRequest"
            HeadlineText="Great! Now tap the name of your new card to expand it; then tap '+ Add prayer'"
            SubText="Add your first prayer request to this card." />

        <!-- BUG-59: Multi-select toolbar overlays search/tag rows at top (visible during long-press) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                ZIndex="10"
                VerticalOptions="Fill"
                AutomationId="Cards_Bar_MultiSelect"
                IsVisible="{Binding IsMultiSelectMode}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                StrokeThickness="0"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="Cancel"
                        AutomationId="Cards_Btn_CancelSelect"
                        Command="{Binding CancelMultiSelectCommand}"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="14"
                        Padding="8,4" />
                <Label Grid.Column="1"
                       Text="{Binding SelectedCountText}"
                       TextColor="White"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="Move to…"
                        AutomationId="Cards_Btn_MoveToBox"
                        Command="{Binding MoveSelectedCommand}"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        FontSize="14"
                        FontAttributes="Bold"
                        Padding="8,4" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>

