<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerListPage"
             x:DataType="viewModels:PrayerListViewModel"
             Title="Prayers">
    <ContentPage.BindingContext>
        <viewModels:PrayerListViewModel />
    </ContentPage.BindingContext>
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding NewCommand}" />
    </ContentPage.ToolbarItems>

    <CollectionView
        x:Name="prayerCollection"
        ItemsSource="{Binding AllPrayers}"
        Margin="20,0"
        SelectionMode="None">

        <CollectionView.Header>
            <Label Text="Prayer Requests"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1"
                   Margin="0,16,0,8" />
        </CollectionView.Header>

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:PrayerRequestDetailViewModel">
                <Grid RowDefinitions="Auto, Auto"
                      Padding="4,10"
                      HorizontalOptions="Fill">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectPrayerCommand}" />
                    </Grid.GestureRecognizers>

                    <!-- Card title (small muted) -->
                    <Label Grid.Row="0"
                           Text="{Binding CardTitle}"
                           FontSize="11"
                           Style="{StaticResource MutedText}" />

                    <!-- Prayer title + answered badge -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Text="{Binding Title}"
                               FontSize="17"
                               TextColor="{Binding IsAnswered, Converter={StaticResource BoolToMutedColor}}"
                               TextDecorations="{Binding IsAnswered, Converter={StaticResource BoolToTextDecoration}}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding AnsweredAtDisplay}"
                               Style="{StaticResource SuccessBadge}"
                               IsVisible="{Binding IsAnswered}"
                               VerticalOptions="Center"
                               Margin="6,0,0,0" />
                    </Grid>

                    <!-- Divider -->
                    <BoxView Grid.Row="1"
                             Style="{StaticResource DividerLine}"
                             VerticalOptions="End" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>
