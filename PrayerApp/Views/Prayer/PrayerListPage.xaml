<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerListPage"
             x:DataType="viewModels:PrayerListViewModel"
             Title="Prayers">
    <ContentPage.BindingContext>
        <viewModels:PrayerListViewModel />
    </ContentPage.BindingContext>
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding NewCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">

        <!-- Filter controls (sticky above the list) -->
        <VerticalStackLayout Grid.Row="0" Margin="20,16,20,0" Spacing="8">

            <Label Text="Prayer Requests"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1" />

            <!-- 3-way status toggle -->
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="4">

                <Button Text="Active"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter="Active"
                        FontSize="13">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsActiveSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding IsActiveSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray600}}" />
                            <Setter Property="TextColor"       Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Grid.Column="1"
                        Text="Answered"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter="Answered"
                        FontSize="13">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsAnsweredSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding IsAnsweredSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray600}}" />
                            <Setter Property="TextColor"       Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Grid.Column="2"
                        Text="All"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter="All"
                        FontSize="13">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsAllSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding IsAllSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray600}}" />
                            <Setter Property="TextColor"       Value="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

            </Grid>

            <!-- Search bar -->
            <SearchBar Text="{Binding SearchText}"
                       Placeholder="Search prayers..."
                       BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=Transparent}" />

            <!-- Tag chip row — only shown when tags exist -->
            <ScrollView Orientation="Horizontal"
                        IsVisible="{Binding HasTags}"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout
                    BindableLayout.ItemsSource="{Binding AvailableTags}"
                    Spacing="6"
                    Padding="0,2,0,6">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TagFilterChipViewModel">
                            <Border Padding="10,4"
                                    StrokeThickness="1.5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                        <Setter Property="Stroke"          Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                        <Setter Property="Stroke"          Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding Tag.Name}"
                                       FontSize="12"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="TextColor" Value="{StaticResource White}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

        <!-- Prayer list -->
        <CollectionView
            x:Name="prayerCollection"
            Grid.Row="1"
            ItemsSource="{Binding FilteredPrayers}"
            Margin="20,0"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" Margin="0,32">
                    <!-- Spinner while loading -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                    <!-- Empty message after load -->
                    <Label Text="No prayers match your filters."
                           Style="{StaticResource MutedText}"
                           IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:PrayerRequestDetailViewModel">
                    <Grid RowDefinitions="Auto, Auto"
                          Padding="4,10"
                          HorizontalOptions="Fill">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectPrayerCommand}" />
                        </Grid.GestureRecognizers>

                        <!-- Card title (small muted) -->
                        <Label Grid.Row="0"
                               Text="{Binding CardTitle}"
                               FontSize="11"
                               Style="{StaticResource MutedText}" />

                        <!-- Prayer title + answered badge -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontSize="17"
                                   TextColor="{Binding IsAnswered, Converter={StaticResource BoolToMutedColor}}"
                                   TextDecorations="{Binding IsAnswered, Converter={StaticResource BoolToTextDecoration}}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding AnsweredAtDisplay}"
                                   Style="{StaticResource SuccessBadge}"
                                   IsVisible="{Binding IsAnswered}"
                                   VerticalOptions="Center"
                                   Margin="6,0,0,0" />
                        </Grid>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
