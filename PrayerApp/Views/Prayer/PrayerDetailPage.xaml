<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:behaviors="clr-namespace:PrayerApp.Behaviors"
             x:Class="PrayerApp.Views.Prayer.PrayerDetailPage"
             x:DataType="viewModels:PrayerRequestDetailViewModel"
             xmlns:models="clr-namespace:PrayerApp.Models"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             xmlns:shared="clr-namespace:PrayerApp.Views.Shared"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Name="page"
             Title="Prayer Request"
             SafeAreaEdges="Container">
    <Grid RowDefinitions="*,Auto,Auto">
        <ScrollView Grid.Row="0">
        <VerticalStackLayout Padding="12,8" Spacing="16">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackgroundTapped" />
            </VerticalStackLayout.GestureRecognizers>

            <!-- VIEW MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsReadOnly}">
                <VerticalStackLayout Spacing="12">

                    <!-- Title -->
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="{Binding Title}"
                               FontSize="{StaticResource FontHeadingLg}"
                               FontAttributes="Bold"
                               SemanticProperties.HeadingLevel="Level1"
                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Image Source="imported.png"
                               HeightRequest="20"
                               WidthRequest="20"
                               IsVisible="{Binding IsImported}"
                               VerticalOptions="Center"
                               SemanticProperties.Description="Imported prayer">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                            </Image.Behaviors>
                        </Image>
                    </HorizontalStackLayout>
                    <!-- Divider -->
                    <BoxView Style="{StaticResource DividerLine}" />

                    <!-- Details -->
                    <Label Text="{Binding Details, FallbackValue='No details added.'}"
                           FontSize="{StaticResource FontBodyLg}"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />

                    <!-- Answered Badge -->
                    <Label Text="{Binding AnsweredAtDisplay}"
                           FontSize="{StaticResource FontSmall}"
                           TextColor="{AppThemeBinding Light={StaticResource SuccessGreen}, Dark={StaticResource SuccessGreenDark}}"
                           FontAttributes="Bold"
                           IsVisible="{Binding IsAnswered}" />

                    <!-- Frequency -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Frequency:"
                               FontSize="{StaticResource FontSmall}"
                               Style="{StaticResource MutedText}"
                               VerticalOptions="Center" />
                        <Label Text="{Binding PrayerFrequencyDisplay}"
                               FontSize="{StaticResource FontSmall}"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Prayed count summary -->
                    <Label Text="{Binding PrayedSummary}"
                           AutomationId="PrayerPrayedSummaryLabel"
                           FontSize="{StaticResource FontSmall}"
                           IsVisible="{Binding HasBeenPrayedFor}"
                           Style="{StaticResource MutedText}" />

                    <!-- Tags (view mode) -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding SelectedTags}"
                                Wrap="Wrap"
                                Direction="Row"
                                IsVisible="{Binding HasTags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TagChipViewModel">
                                <Border BackgroundColor="{Binding ChipColor}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8,4"
                                        Margin="2,2">
                                    <Label Text="{Binding Name}"
                                           TextColor="{StaticResource White}"
                                           FontSize="{StaticResource FontCaption}"
                                           VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Share"
                                AutomationId="Detail_Btn_Share"
                                SemanticProperties.Hint="Share this prayer request"
                                Style="{StaticResource SmallActionButton}"
                                Command="{Binding ShareCommand}"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="1"
                                Text="Mark Answered"
                                AutomationId="Detail_Btn_MarkAnswered"
                                SemanticProperties.Hint="Mark this prayer as answered"
                                Style="{StaticResource AnsweredButton}"
                                Command="{Binding MarkAnsweredCommand}"
                                IsVisible="{Binding IsNotAnswered}"
                                HorizontalOptions="Fill" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- EDIT MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsEditable}">
                <VerticalStackLayout Spacing="12">

                    <!-- Prayer Card -->
                    <Label Text="Belongs to Card"
                           Style="{StaticResource FormLabel}" />
                    <shared:StyledPicker Title="Select Card"
                                         AutomationId="Detail_Picker_Card"
                                         ItemsSource="{Binding AvailableCards}"
                                         SelectedItem="{Binding SelectedCard}"
                                         ItemDisplayBinding="{Binding Title, x:DataType=models:PrayerCard}"
                                         SemanticHint="Tap to change which card this prayer belongs to" />

                    <!-- Title -->
                    <Label Text="Title"
                           Style="{StaticResource FormLabel}" />
                    <Entry x:Name="TitleEntry"
                           Text="{Binding Title}"
                           AutomationId="Detail_Entry_Title"
                           Placeholder="Prayer title"
                           SemanticProperties.Hint="Prayer request title"
                           HorizontalOptions="Fill">
                        <Entry.Behaviors>
                            <behaviors:SelectAllOnFocusBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <BoxView Style="{StaticResource PickerInsetSeparator}" Margin="0,4,0,0" />

                    <!-- Details -->
                    <Label Text="Details"
                           Style="{StaticResource FormLabel}" />
                    <Editor x:Name="DetailsEditor"
                            Text="{Binding Details}"
                            AutomationId="Detail_Entry_Details"
                            Placeholder="Add details..."
                            SemanticProperties.Hint="Prayer request details or Scripture reference"
                            HeightRequest="100"
                            HorizontalOptions="Fill" />
                    <BoxView Style="{StaticResource PickerInsetSeparator}" Margin="0,4,0,0" />

                    <!-- Scheduling group -->
                    <Border Style="{StaticResource PrayerCardBorder}" Padding="16" Margin="0,-4,0,0">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <Label Text="Reminders"
                                       Style="{StaticResource FormSectionHeader}"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        AutomationId="Detail_Switch_Reminders"
                                        IsToggled="{Binding CanNotify}"
                                        SemanticProperties.Hint="Enable reminders for this request"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Frequency (visible when notifications enabled) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowNotifyTime}">
                                <Label Text="Frequency" Style="{StaticResource FormLabel}" />
                                <shared:StyledPicker Title="Select Frequency"
                                                     AutomationId="Detail_Picker_Frequency"
                                                     ItemsSource="{Binding FrequencyOptions}"
                                                     SelectedItem="{Binding PrayerFrequency}"
                                                     SemanticHint="How often to be reminded" />
                            </VerticalStackLayout>

                            <!-- Reminder Time -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowNotifyTime}">
                                <Label Text="Reminder Time" Style="{StaticResource FormLabel}" />
                                <TimePicker AutomationId="Detail_Picker_ReminderTime" Time="{Binding NotifyTime}" />
                            </VerticalStackLayout>

                            <!-- Day of Week (Weekly only) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowDayOfWeek}">
                                <Label Text="Day of Week" Style="{StaticResource FormLabel}" />
                                <shared:StyledPicker AutomationId="Detail_Picker_DayOfWeek"
                                                     ItemsSource="{Binding DaysOfWeek}"
                                                     SelectedItem="{Binding SelectedDayOfWeek}"
                                                     Title="Select Day" />
                            </VerticalStackLayout>

                            <!-- Day of Month (Monthly only) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowDayOfMonth}">
                                <Label Text="Day of Month" Style="{StaticResource FormLabel}" />
                                <shared:StyledPicker AutomationId="Detail_Picker_DayOfMonth"
                                                     ItemsSource="{Binding DaysOfMonth}"
                                                     SelectedItem="{Binding SelectedDayOfMonth}"
                                                     Title="Select Day" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Answered group -->
                    <Border Style="{StaticResource PrayerCardBorder}" Padding="16" Margin="0,-4,0,0">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <Label Text="Answered"
                                       Style="{StaticResource FormSectionHeader}"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        AutomationId="Detail_Switch_Answered"
                                        IsToggled="{Binding IsAnswered}"
                                        SemanticProperties.Hint="Mark this request as answered"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Answered On (visible only when answered) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsAnswered}">
                                <Label Text="Answered on" Style="{StaticResource FormLabel}" />
                                <DatePicker AutomationId="Detail_Picker_AnsweredOn"
                                            Date="{Binding AnsweredAt}"
                                            MinimumDate="{Binding CreatedAtDate}"
                                            MaximumDate="{Binding Today}"
                                            SemanticProperties.Description="Answered on"
                                            SemanticProperties.Hint="Select the date this request was answered" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Tags (edit mode) — label, chips, and + button flow inline -->
                    <FlexLayout x:Name="editTagChips"
                                Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Center">
                        <!-- Label + chips rebuilt in code-behind; + button is last child -->
                        <Label x:Name="tagsLabel" Text="Tags"
                               Style="{StaticResource FormLabel}"
                               VerticalOptions="Center"
                               Margin="0,0,6,0" />
                        <Border x:Name="addTagButton"
                                AutomationId="Detail_Btn_AddTags"
                                StrokeShape="RoundRectangle 14"
                                WidthRequest="28" HeightRequest="28"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300},
                                                         Dark={StaticResource CardBorderDark}}"
                                BackgroundColor="Transparent"
                                Margin="2,2"
                                SemanticProperties.Description="Add tags"
                                SemanticProperties.Hint="Double tap to open tag picker">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenTagPickerCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="+"
                                   FontSize="{StaticResource FontHeadline}"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                               Dark={StaticResource PrimaryDark}}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </FlexLayout>

                    <!-- Divider before action buttons -->
                    <BoxView Style="{StaticResource DividerLine}" Margin="0,8,0,0" />

                    <!-- Delete Button — Save and Save+ are in the navbar -->
                    <Button Text="Delete"
                            AutomationId="Detail_Btn_Delete"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource DangerButton}"
                            IsVisible="{Binding IsNew, Converter={StaticResource InverseBool}}"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — NameRequest step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameRequest"
            HeadlineText="Enter your prayer request and tap Save" />

        <!-- Save indicator -->
        <ActivityIndicator Grid.Row="0" Grid.RowSpan="3"
                           Style="{StaticResource SaveActivityIndicator}"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}" />

    </Grid>
</ContentPage>
