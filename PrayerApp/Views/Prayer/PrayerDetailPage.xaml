<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerDetailPage"
             x:DataType="viewModels:PrayerRequestDetailViewModel"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:Name="page"
             Title="Prayer Request">
    <ContentPage.BindingContext>
        <viewModels:PrayerRequestDetailViewModel />
    </ContentPage.BindingContext>
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
        <VerticalStackLayout Padding="12,8" Spacing="16">

            <!-- VIEW MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsReadOnly}">
                <VerticalStackLayout Spacing="12">

                    <!-- Title -->
                    <Label Text="{Binding Title}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Tertiary}" />
                    <!-- Divider -->
                    <BoxView Style="{StaticResource DividerLine}" />

                    <!-- Details -->
                    <Label Text="{Binding Details, FallbackValue='No details added.'}"
                           FontSize="15"
                           TextColor="{StaticResource OffBlack}" />

                    <!-- Answered Badge -->
                    <Label Text="{Binding AnsweredAtDisplay}"
                           FontSize="13"
                           TextColor="{StaticResource SuccessGreen}"
                           FontAttributes="Bold"
                           IsVisible="{Binding IsAnswered}" />

                    <!-- Frequency -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Frequency:"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                        <Label Text="{Binding PrayerFrequencyDisplay}"
                               FontSize="13"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Tags (view mode) -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding SelectedTags}"
                                Wrap="Wrap"
                                Direction="Row"
                                IsVisible="{Binding HasTags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TagChipViewModel">
                                <Border BackgroundColor="{Binding ChipColor}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8,4"
                                        Margin="2,2">
                                    <Label Text="{Binding Name}"
                                           TextColor="White"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="6">
                        <Button Grid.Column="0"
                                Text="Share"
                                Style="{StaticResource SmallActionButton}"
                                Command="{Binding ShareCommand}"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="1"
                                Text="Edit"
                                Style="{StaticResource SmallActionButton}"
                                Command="{Binding EditPrayerCommand}"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="2"
                                Text="Mark Answered"
                                Style="{StaticResource AnsweredButton}"
                                Command="{Binding MarkAnsweredCommand}"
                                IsVisible="{Binding IsNotAnswered}"
                                HorizontalOptions="Fill" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- EDIT MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsEditable}">
                <VerticalStackLayout Spacing="12">

                    <!-- Title -->
                    <Label Text="Title"
                           Style="{StaticResource FormLabel}" />
                    <Entry Text="{Binding Title}"
                           Placeholder="Prayer title"
                           SemanticProperties.Hint="Prayer request title"
                           HorizontalOptions="Fill" />

                    <!-- Details -->
                    <Label Text="Details"
                           Style="{StaticResource FormLabel}" />
                    <Editor Text="{Binding Details}"
                            Placeholder="Add details..."
                            SemanticProperties.Hint="Prayer request details or Scripture reference"
                            HeightRequest="100"
                            HorizontalOptions="Fill" />

                    <!-- Frequency -->
                    <Label Text="Frequency"
                           Style="{StaticResource FormLabel}" />
                    <Picker Title="Select Frequency"
                            ItemsSource="{Binding FrequencyOptions}"
                            ItemDisplayBinding="{Binding .}"
                            SelectedItem="{Binding PrayerFrequency}"
                            SemanticProperties.Hint="How often to be reminded"
                            HorizontalOptions="Fill" />

                    <!-- Notifications Switch -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Notifications"
                               VerticalOptions="Center" />
                        <Switch IsToggled="{Binding CanNotify}"
                                SemanticProperties.Description="Enable reminders for this request"
                                VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup>
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <!-- Answered Switch -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Answered"
                               VerticalOptions="Center" />
                        <Switch IsToggled="{Binding IsAnswered}"
                                SemanticProperties.Description="Mark this request as answered"
                                VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup>
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <!-- Tags (edit mode) -->
                    <Label Text="Tags" Style="{StaticResource FormLabel}" />

                    <!-- Selected tag chips (removable) -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding SelectedTags}"
                                Wrap="Wrap"
                                Direction="Row"
                                IsVisible="{Binding HasTags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TagChipViewModel">
                                <Border BackgroundColor="{Binding ChipColor}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="6,4"
                                        Margin="2,2">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                               TextColor="White"
                                               FontSize="12"
                                               VerticalOptions="Center" />
                                        <Label Text="×"
                                               TextColor="White"
                                               FontSize="14"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding RemoveCommand}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- Tag search entry -->
                    <Entry Text="{Binding TagSearchText}"
                           Placeholder="Add tags..."
                           ReturnCommand="{Binding SubmitTagEntryCommand}"
                           HorizontalOptions="Fill" />

                    <!-- Suggestions list -->
                    <Border IsVisible="{Binding HasSuggestions}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            StrokeShape="RoundRectangle 6"
                            Padding="0">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding SuggestedTags}"
                                             Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="{x:Null}">
                                    <Grid Padding="12,10"
                                          BackgroundColor="Transparent">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.AddSuggestedTagCommand, Source={x:Reference page}}"
                                                CommandParameter="{Binding Id}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{Binding Name}" FontSize="14" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Save / Delete Buttons -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Delete"
                                Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="1"
                                Text="Save"
                                Command="{Binding SaveCommand}"
                                HorizontalOptions="Fill" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — NameRequest step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameRequest"
            HeadlineText="Enter your prayer request and tap Save" />

    </Grid>
</ContentPage>
