<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerDetailPage"
             x:DataType="viewModels:PrayerRequestDetailViewModel"
             Title="Prayer Request">
    <ContentPage.BindingContext>
        <viewModels:PrayerRequestDetailViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout Padding="12,8" Spacing="16">

            <!-- VIEW MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsReadOnly}">
                <VerticalStackLayout Spacing="12">

                    <!-- Title -->
                    <Label Text="{Binding Title}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Tertiary}" />

                    <!-- Divider -->
                    <BoxView Color="{StaticResource Primary}"
                             Opacity="0.4"
                             HeightRequest="1"
                             HorizontalOptions="Fill" />

                    <!-- Details -->
                    <Label Text="{Binding Details, FallbackValue='No details added.'}"
                           FontSize="15"
                           TextColor="{StaticResource OffBlack}" />

                    <!-- Answered Badge -->
                    <Label Text="{Binding AnsweredAtDisplay}"
                           FontSize="13"
                           TextColor="#4CAF50"
                           FontAttributes="Bold"
                           IsVisible="{Binding IsAnswered}" />

                    <!-- Frequency -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Frequency:"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                        <Label Text="{Binding PrayerFrequencyDisplay}"
                               FontSize="13"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="6">
                        <!-- Set Reminder: placeholder for Phase 3 notification scheduling -->
                        <Button Grid.Column="0"
                                Text="Set Reminder"
                                FontSize="13"
                                Padding="8,6"
                                IsEnabled="False"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="1"
                                Text="Edit"
                                FontSize="13"
                                Padding="8,6"
                                Command="{Binding EditPrayerCommand}"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="2"
                                Text="Mark Answered"
                                FontSize="13"
                                Padding="8,6"
                                Command="{Binding MarkAnsweredCommand}"
                                BackgroundColor="{StaticResource WarmGold}"
                                TextColor="White"
                                IsVisible="{Binding IsNotAnswered}"
                                HorizontalOptions="Fill" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- EDIT MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsEditable}">
                <VerticalStackLayout Spacing="12">

                    <!-- Title -->
                    <Label Text="Title"
                           FontSize="13"
                           TextColor="{StaticResource Tertiary}" />
                    <Entry Text="{Binding Title}"
                           Placeholder="Prayer title"
                           HorizontalOptions="Fill" />

                    <!-- Details -->
                    <Label Text="Details"
                           FontSize="13"
                           TextColor="{StaticResource Tertiary}" />
                    <Editor Text="{Binding Details}"
                            Placeholder="Add details..."
                            HeightRequest="100"
                            HorizontalOptions="Fill" />

                    <!-- Frequency -->
                    <Label Text="Frequency"
                           FontSize="13"
                           TextColor="{StaticResource Tertiary}" />
                    <Picker Title="Select Frequency"
                            ItemsSource="{Binding FrequencyOptions}"
                            ItemDisplayBinding="{Binding .}"
                            SelectedItem="{Binding PrayerFrequency}"
                            HorizontalOptions="Fill" />

                    <!-- Notifications Switch -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Notifications"
                               VerticalOptions="Center" />
                        <Switch IsToggled="{Binding CanNotify}"
                                VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup>
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <!-- Answered Switch -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Answered"
                               VerticalOptions="Center" />
                        <Switch IsToggled="{Binding IsAnswered}"
                                VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup>
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                                        Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <!-- Save / Delete Buttons -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Delete"
                                Command="{Binding DeleteCommand}"
                                BackgroundColor="IndianRed"
                                TextColor="White"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="1"
                                Text="Save"
                                Command="{Binding SaveCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                HorizontalOptions="Fill" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
