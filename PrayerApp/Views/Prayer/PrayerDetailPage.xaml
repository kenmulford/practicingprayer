<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerDetailPage"
             x:DataType="viewModels:PrayerRequestDetailViewModel"
             xmlns:models="clr-namespace:PrayerApp.Models"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:Name="page"
             Title="Prayer Request"
             SafeAreaEdges="Container">
    <ContentPage.BindingContext>
        <viewModels:PrayerRequestDetailViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
        <VerticalStackLayout Padding="12,8" Spacing="16">

            <!-- VIEW MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsReadOnly}">
                <VerticalStackLayout Spacing="12">

                    <!-- Title -->
                    <Label Text="{Binding Title}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                    <!-- Divider -->
                    <BoxView Style="{StaticResource DividerLine}" />

                    <!-- Details -->
                    <Label Text="{Binding Details, FallbackValue='No details added.'}"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />

                    <!-- Answered Badge -->
                    <Label Text="{Binding AnsweredAtDisplay}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource SuccessGreen}, Dark={StaticResource SuccessGreenDark}}"
                           FontAttributes="Bold"
                           IsVisible="{Binding IsAnswered}" />

                    <!-- Frequency -->
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Frequency:"
                               FontSize="13"
                               Style="{StaticResource MutedText}"
                               VerticalOptions="Center" />
                        <Label Text="{Binding PrayerFrequencyDisplay}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Tags (view mode) -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding SelectedTags}"
                                Wrap="Wrap"
                                Direction="Row"
                                IsVisible="{Binding HasTags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TagChipViewModel">
                                <Border BackgroundColor="{Binding ChipColor}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="8,4"
                                        Margin="2,2">
                                    <Label Text="{Binding Name}"
                                           TextColor="{StaticResource White}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Share"
                                Style="{StaticResource SmallActionButton}"
                                Command="{Binding ShareCommand}"
                                HorizontalOptions="Fill" />
                        <Button Grid.Column="1"
                                Text="Mark Answered"
                                Style="{StaticResource AnsweredButton}"
                                Command="{Binding MarkAnsweredCommand}"
                                IsVisible="{Binding IsNotAnswered}"
                                HorizontalOptions="Fill" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- EDIT MODE -->
            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16"
                    IsVisible="{Binding IsEditable}">
                <VerticalStackLayout Spacing="12">

                    <!-- Prayer Card -->
                    <Label Text="Prayer Card"
                           Style="{StaticResource FormLabel}" />
                    <Picker Title="Select Card"
                            ItemsSource="{Binding AvailableCards}"
                            SelectedItem="{Binding SelectedCard}"
                            ItemDisplayBinding="{Binding Title, x:DataType=models:PrayerCard}"
                            SemanticProperties.Hint="Which prayer card this request belongs to"
                            HorizontalOptions="Fill" />

                    <!-- Title -->
                    <Label Text="Title"
                           Style="{StaticResource FormLabel}" />
                    <Entry x:Name="TitleEntry"
                           Text="{Binding Title}"
                           Placeholder="Prayer title"
                           SemanticProperties.Hint="Prayer request title"
                           HorizontalOptions="Fill" />

                    <!-- Details -->
                    <Label Text="Details"
                           Style="{StaticResource FormLabel}" />
                    <Editor Text="{Binding Details}"
                            Placeholder="Add details..."
                            SemanticProperties.Hint="Prayer request details or Scripture reference"
                            HeightRequest="100"
                            HorizontalOptions="Fill" />

                    <!-- Scheduling group -->
                    <Border Style="{StaticResource PrayerCardBorder}" Padding="16" Margin="0,-4,0,0">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <Label Text="Reminders"
                                       Style="{StaticResource SectionHeading}"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding CanNotify}"
                                        SemanticProperties.Description="Enable reminders for this request"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Frequency (visible when notifications enabled) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowNotifyTime}">
                                <Label Text="Frequency" Style="{StaticResource FormLabel}" />
                                <Picker Title="Select Frequency"
                                        ItemsSource="{Binding FrequencyOptions}"
                                        ItemDisplayBinding="{Binding ., x:DataType=x:String}"
                                        SelectedItem="{Binding PrayerFrequency}"
                                        SemanticProperties.Hint="How often to be reminded"
                                        HorizontalOptions="Fill" />
                            </VerticalStackLayout>

                            <!-- Reminder Time -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowNotifyTime}">
                                <Label Text="Reminder Time" Style="{StaticResource FormLabel}" />
                                <TimePicker Time="{Binding NotifyTime}" />
                            </VerticalStackLayout>

                            <!-- Day of Week (Weekly only) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowDayOfWeek}">
                                <Label Text="Day of Week" Style="{StaticResource FormLabel}" />
                                <Picker ItemsSource="{Binding DaysOfWeek}"
                                        SelectedItem="{Binding SelectedDayOfWeek}"
                                        Title="Select Day" />
                            </VerticalStackLayout>

                            <!-- Day of Month (Monthly only) -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowDayOfMonth}">
                                <Label Text="Day of Month" Style="{StaticResource FormLabel}" />
                                <Picker ItemsSource="{Binding DaysOfMonth}"
                                        SelectedItem="{Binding SelectedDayOfMonth}"
                                        Title="Select Day" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Answered Switch -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Answered"
                               VerticalOptions="Center" />
                        <Switch IsToggled="{Binding IsAnswered}"
                                SemanticProperties.Description="Mark this request as answered"
                                VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Tags (edit mode) -->
                    <Label Text="Tags" Style="{StaticResource FormLabel}" />

                    <!-- Selected tag chips (removable) -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding SelectedTags}"
                                Wrap="Wrap"
                                Direction="Row"
                                IsVisible="{Binding HasTags}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:TagChipViewModel">
                                <Border BackgroundColor="{Binding ChipColor}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="6,4"
                                        Margin="2,2">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource White}"
                                               FontSize="12"
                                               VerticalOptions="Center" />
                                        <Label Text="×"
                                               TextColor="{StaticResource White}"
                                               FontSize="14"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding RemoveCommand}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <!-- Tag search entry -->
                    <Entry x:Name="tagEntry"
                           Text="{Binding TagSearchText}"
                           Placeholder="Add tags..."
                           ReturnCommand="{Binding SubmitTagEntryCommand}"
                           ReturnType="Done"
                           Completed="OnTagEntryCompleted"
                           HorizontalOptions="Fill" />

                    <!-- Suggestions list — CollectionView provides both tap (via
                         SelectionChanged) and scrolling. HeightRequest gives iOS
                         a definite frame; without it, CollectionView reports zero
                         intrinsic height inside a page-level ScrollView. -->
                    <Border IsVisible="{Binding HasSuggestions}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource CardBorderDark}}"
                            StrokeShape="RoundRectangle 6"
                            Padding="0">
                        <CollectionView ItemsSource="{Binding SuggestedTags}"
                                        SelectionMode="Single"
                                        SelectionChanged="OnSuggestionSelected"
                                        HeightRequest="180">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:PrayerTag">
                                    <Grid Padding="14,12">
                                        <Label Text="{Binding Name}" FontSize="15" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- Divider before action buttons -->
                    <BoxView Style="{StaticResource DividerLine}" Margin="0,8,0,0" />

                    <!-- Delete Button — Save is in the navbar -->
                    <Button Text="Delete"
                            Command="{Binding DeleteCommand}"
                            Style="{StaticResource DangerButton}"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — NameRequest step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="NameRequest"
            HeadlineText="Enter your prayer request and tap Save" />

    </Grid>
</ContentPage>
