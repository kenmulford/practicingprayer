<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerDetailPage"
             x:DataType="viewModels:PrayerRequestDetailViewModel"
             Title="Prayer Request">
    <ContentPage.BindingContext>
        <viewModels:PrayerRequestDetailViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout
        Padding="10,0"
        Spacing="10">
            <Border
                
                Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>
                <VerticalStackLayout 
                    Spacing="10" 
                    Margin="5">
                    <!-- Prayer Title -->
                    <HorizontalStackLayout
                        Spacing="10">
                        <Entry 
                            x:Name="TitleEntry"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            WidthRequest="300"
                            Placeholder="Title"
                            IsReadOnly="{Binding IsReadOnly}"
                            Text="{Binding Title}" />
                    </HorizontalStackLayout>
                    <!-- Details -->
                    <VerticalStackLayout
                        Spacing="10"
                        Margin="5">
                        <Editor
                            x:Name="DetailsEditor"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Placeholder="Type your prayer details here.."
                            IsReadOnly="{Binding IsReadOnly}"
                            Text="{Binding Details}" />
                    </VerticalStackLayout>

                    <!-- Frequency -->
                    <VerticalStackLayout
                        Spacing="10"
                        Margin="5">
                        <Picker
                            x:Name="FrequencyPicker"
                            Title="Select Frequency"
                            ItemsSource="{Binding FrequencyOptions}"
                            ItemDisplayBinding="{Binding .}"
                            SelectedItem="{Binding PrayerFrequency}"
                            IsEnabled="{Binding IsEditable}"
                            HorizontalOptions="Start"
                            WidthRequest="300" />
                    </VerticalStackLayout>

                    <!-- Allow Notifications (CanNotify) -->
                    <HorizontalStackLayout Spacing="10">
                        <Label
                            Text="Allow Notifications?"
                            WidthRequest="100"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="chkCanNotify"
                            OnColor="{StaticResource Secondary}"
                            IsToggled="{Binding CanNotify}"
                            IsEnabled="{Binding IsEditable}"
                            VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                    Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                    Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <!-- Is Answered -->
                    <HorizontalStackLayout Spacing="10">

                        <Label
                            Text="Answered?"
                            WidthRequest="100"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="chkIsAnswered"
                            OnColor="{StaticResource Secondary}"
                            IsToggled="{Binding IsAnswered}"
                            IsEnabled="{Binding IsEditable}"
                            VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                        Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                        Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="4">
                        <Button 
                            StyleClass=""
                            HorizontalOptions="Start"
                            Command="{Binding DeleteCommand}"
                            Text="Delete"
                            IsVisible="{Binding IsEditable}" />
                        <Button 
                            StyleClass=""
                            Grid.Column="1"
                            HorizontalOptions="End"
                            Command="{Binding SaveCommand}"
                            Text="Save"
                            IsVisible="{Binding IsEditable}" />
                        <Button
                            StyleClass=""
                            Grid.ColumnSpan="2"
                            HorizontalOptions="End"
                            Command="{Binding EditPrayerCommand}"
                            Text="Edit"
                            IsVisible="{Binding IsReadOnly}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>