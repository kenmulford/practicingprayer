<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Prayer.PrayerDetailPage"
             x:DataType="viewModels:PrayerRequestDetailViewModel"
             Title="Prayer Request">
    <ContentPage.BindingContext>
        <viewModels:PrayerRequestDetailViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout
        Padding="10,0"
        Spacing="10">
            <Border
                Padding="10">
                <VerticalStackLayout 
                    Spacing="10" 
                    Margin="5">
                    <!-- Prayer Title -->
                    <HorizontalStackLayout
                        Spacing="10">
                        <Entry 
                            x:Name="TitleEntry"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            WidthRequest="300"
                            Placeholder="Title"
                            Text="{Binding Title}" />
                    </HorizontalStackLayout>
                    <!-- Details -->
                    <VerticalStackLayout
                        Spacing="10"
                        Margin="5">
                        <Editor
                            x:Name="DetailsEditor"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"
                            Placeholder="Type your prayer details here.."
                            Text="{Binding Details}" />
                    </VerticalStackLayout>

                    <!-- Tags Section -->
                    <VerticalStackLayout Spacing="10" Margin="5">
                        <Label Text="Tags" FontSize="16" FontAttributes="Bold"/>
                        <CollectionView 
                            ItemsSource="{Binding TagSelectionViewModel.AllTags}"
                            SelectionMode="Multiple">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:PrayerTagItemViewModel">
                                    <HorizontalStackLayout Spacing="10" Padding="5">
                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                        <Label Text="{Binding Name}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- Frequency -->
                    <VerticalStackLayout
                        Spacing="10"
                        Margin="5">
                        <Picker
                            x:Name="FrequencyPicker"
                            Title="Select Frequency"
                            ItemsSource="{Binding FrequencyOptions}"
                            ItemDisplayBinding="{Binding .}"
                            SelectedItem="{Binding PrayerFrequency}"
                            HorizontalOptions="Start"
                            WidthRequest="300" />
                    </VerticalStackLayout>

                    <!-- Allow Notifications (CanNotify) -->
                    <HorizontalStackLayout Spacing="10">
                        <Label
                            Text="Allow Notifications?"
                            WidthRequest="100"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="chkCanNotify"
                            OnColor="{StaticResource Secondary}"
                            IsToggled="{Binding CanNotify}"
                            VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                    Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                    Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <!-- Is Answered -->
                    <HorizontalStackLayout Spacing="10">

                        <Label
                            Text="Answered?"
                            WidthRequest="100"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="chkIsAnswered"
                            OnColor="{StaticResource Secondary}"
                            IsToggled="{Binding IsAnswered}"
                            VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                        Value="{StaticResource Primary}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor"
                                        Value="{StaticResource Gray600}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="4">
                        <Button 
                            StyleClass=""
                            HorizontalOptions="Start"
                            Command="{Binding DeleteCommand}"
                            Text="Delete" />
                        <Button 
                            StyleClass=""
                            Grid.Column="1"
                            HorizontalOptions="End"
                            Command="{Binding SaveCommand}"
                            Text="Save" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>