<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:shared="clr-namespace:PrayerApp.Views.Shared"
             x:Class="PrayerApp.Views.QuickAddPage"
             x:DataType="viewModels:QuickAddViewModel"
             Title="Quick Add"
             SafeAreaEdges="All">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">

            <Border IsVisible="{Binding ShowTip}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource OverdueLight}, Dark={StaticResource OverdueDark}}"
                    StrokeThickness="0"
                    Padding="14,10"
                    Margin="0,0,0,4">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Label Text="Pick a destination below, or keep the default Quick Add card."
                           FontSize="13"
                           LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextSecondaryDark}}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="✕"
                            AutomationId="QuickAdd_Btn_DismissTip"
                            Command="{Binding DismissTipCommand}"
                            SemanticProperties.Description="Dismiss tip"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}"
                            FontSize="14"
                            Padding="4"
                            BorderWidth="0"
                            WidthRequest="32"
                            HeightRequest="32"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label Text="Prayer Title"
                   Style="{StaticResource FormSectionHeader}"
                   Margin="0,4,0,0" />

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16">
                <Entry x:Name="TitleEntry"
                       Text="{Binding Title}"
                       AutomationId="QuickAdd_Entry_Title"
                       Placeholder="Enter prayer title"
                       SemanticProperties.Hint="Title for your prayer request"
                       HorizontalOptions="Fill" />
            </Border>

            <Label Text="Destination"
                   Style="{StaticResource FormSectionHeader}"
                   Margin="0,4,0,0" />

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="0">
                <VerticalStackLayout Spacing="0">

                    <Grid Padding="16,11" ColumnDefinitions="*, Auto" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="Add to"
                               Style="{StaticResource FormLabel}"
                               VerticalOptions="Center" />
                        <Grid Grid.Column="1"
                              Padding="3"
                              ColumnDefinitions="Auto, Auto"
                              ColumnSpacing="2"
                              VerticalOptions="Center"
                              HorizontalOptions="End">
                            <Border Grid.Column="0"
                                    AutomationId="QuickAdd_Seg_NewCard"
                                    Padding="10,6"
                                    MinimumHeightRequest="44"
                                    MinimumWidthRequest="108"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 5"
                                    BackgroundColor="Transparent">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsNewCardMode}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="New"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsNewCardMode}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetNewCardModeCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="1"
                                    AutomationId="QuickAdd_Seg_ExistingCard"
                                    Padding="10,6"
                                    MinimumHeightRequest="44"
                                    MinimumWidthRequest="44"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 5"
                                    BackgroundColor="Transparent">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsExistingCardMode}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="Existing"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExistingCardMode}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetExistingCardModeCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </Grid>

                    <VerticalStackLayout Spacing="0" IsVisible="{Binding IsNewCardMode}">
                        <BoxView Style="{StaticResource PickerInsetSeparator}" />
                        <Grid Padding="16,11" ColumnDefinitions="Auto, *" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="Collection"
                                   Style="{StaticResource FormLabel}"
                                   VerticalOptions="Center" />
                            <shared:StyledPicker Grid.Column="1"
                                                 ItemsSource="{Binding AvailableBoxes}"
                                                 SelectedItem="{Binding SelectedBox}"
                                                 AutomationId="QuickAdd_Picker_Box"
                                                 SemanticHint="Choose which collection the new card belongs to"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="Fill"
                                                 HorizontalTextAlignment="End" />
                        </Grid>
                        <BoxView Style="{StaticResource PickerInsetSeparator}" />
                        <VerticalStackLayout Padding="16,11" Spacing="6">
                            <Label Text="Card Title"
                                   Style="{StaticResource FormLabel}" />
                            <Entry Text="{Binding CardTitle}"
                                   AutomationId="QuickAdd_Entry_CardTitle"
                                   Placeholder="Card title"
                                   SemanticProperties.Hint="Title for the new prayer card"
                                   HorizontalOptions="Fill" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout x:Name="cardGroupsList"
                                 BindableLayout.ItemsSource="{Binding AvailableCardGroups}"
                                 AutomationId="QuickAdd_List_Groups"
                                 IsVisible="{Binding ShowCardPickerList}"
                                 Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CardCollectionGroup">
                        <VerticalStackLayout Spacing="0" Margin="0,4,0,10">
                            <Label Text="{Binding CollectionName}"
                                   Style="{StaticResource PickerSectionHeader}"
                                   Margin="4,0,0,6" />
                            <Border Style="{StaticResource PickerGroupCard}">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Cards}"
                                                     Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:CardPickerItem">
                                            <VerticalStackLayout Spacing="0">
                                                <Border Style="{StaticResource PickerRow}"
                                                        AutomationId="{Binding CardId, StringFormat='QuickAdd_Item_{0}'}">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <Label Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               VerticalOptions="Center"
                                                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                                                        <Label Grid.Column="1"
                                                               Text="&#x2713;"
                                                               IsVisible="False"
                                                               VerticalOptions="Center"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="IsVisible" Value="True" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                    </Grid>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnCardItemTapped" />
                                                    </Border.GestureRecognizers>
                                                </Border>
                                                <BoxView Style="{StaticResource PickerInsetSeparator}" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Border x:Name="selectedCardSummary"
                    Style="{StaticResource PickerGroupCard}"
                    Padding="16,13"
                    IsVisible="{Binding ShowSelectedCardSummary}">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="{Binding SelectedCard.Title}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label Grid.Column="1"
                           Text="Change"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChangeCardTapped" />
                </Border.GestureRecognizers>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Text="Cancel"
                        AutomationId="QuickAdd_Btn_Cancel"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Add"
                        AutomationId="QuickAdd_Btn_Add"
                        Command="{Binding SaveCommand}"
                        SemanticProperties.Hint="Save this prayer request"
                        HorizontalOptions="Fill" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
