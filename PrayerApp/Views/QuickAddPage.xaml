<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:models="clr-namespace:PrayerApp.Models"
             x:Class="PrayerApp.Views.QuickAddPage"
             x:DataType="viewModels:QuickAddViewModel"
             Title="Quick Add"
             SafeAreaEdges="All">
    <ContentPage.BindingContext>
        <viewModels:QuickAddViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Prayer Title"
                           Style="{StaticResource FormLabel}" />
                    <Entry Text="{Binding Title}"
                           AutomationId="QuickAdd_Entry_Title"
                           Placeholder="Enter prayer title"
                           HorizontalOptions="Fill" />

                    <Label Text="Add to Card"
                           Style="{StaticResource FormLabel}" />
                    <Picker ItemsSource="{Binding Cards}"
                            AutomationId="QuickAdd_Picker_Card"
                            SelectedItem="{Binding SelectedCard}"
                            ItemDisplayBinding="{Binding Title, x:DataType=models:PrayerCard}"
                            Title="Select a card"
                            SemanticProperties.Hint="Select which prayer card to add this request to"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="Cancel"
                        AutomationId="QuickAdd_Btn_Cancel"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Add"
                        AutomationId="QuickAdd_Btn_Add"
                        Command="{Binding SaveCommand}"
                        HorizontalOptions="Fill" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
