<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.QuickAddPage"
             x:DataType="viewModels:QuickAddViewModel"
             Title="Quick Add">
    <ContentPage.BindingContext>
        <viewModels:QuickAddViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Prayer Title"
                           FontSize="13"
                           TextColor="{StaticResource Tertiary}" />
                    <Entry Text="{Binding Title}"
                           Placeholder="Enter prayer title"
                           HorizontalOptions="Fill" />

                    <Label Text="Add to Card"
                           FontSize="13"
                           TextColor="{StaticResource Tertiary}" />
                    <Picker ItemsSource="{Binding Cards}"
                            SelectedItem="{Binding SelectedCard}"
                            ItemDisplayBinding="{Binding Title}"
                            Title="Select a card"
                            HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Add"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        HorizontalOptions="Fill" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
