<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.QuickAddPage"
             x:DataType="viewModels:QuickAddViewModel"
             Title="Quick Add"
             SafeAreaEdges="All">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Prayer Title"
                           Style="{StaticResource FormLabel}" />
                    <Entry Text="{Binding Title}"
                           AutomationId="QuickAdd_Entry_Title"
                           Placeholder="Enter prayer title"
                           SemanticProperties.Hint="Title for your prayer request"
                           HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="Cancel"
                        AutomationId="QuickAdd_Btn_Cancel"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Add"
                        AutomationId="QuickAdd_Btn_Add"
                        Command="{Binding SaveCommand}"
                        HorizontalOptions="Fill" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
