<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:behaviors="clr-namespace:PrayerApp.Behaviors"
             x:Class="PrayerApp.Views.Boxes.BoxDetailPage"
             x:DataType="viewModels:BoxDetailViewModel"
             Title="Collection"
             SafeAreaEdges="Container">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save"
                     Command="{Binding SaveCommand}"
                     SemanticProperties.Hint="Save collection changes"
                     x:DataType="viewModels:BoxDetailViewModel" />
    </ContentPage.ToolbarItems>

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="24">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackgroundTapped" />
            </VerticalStackLayout.GestureRecognizers>

            <!-- System collection note -->
            <Border IsVisible="{Binding IsSystem}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource CardBorderDark}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,10">
                <Label Text="This is a system-managed collection. It cannot be renamed or deleted."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource TextSecondaryDark}}" />
            </Border>

            <!-- Name field -->
            <Border Style="{StaticResource PrayerCardBorder}" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Name" Style="{StaticResource FormLabel}" />
                    <Entry x:Name="NameEntry"
                           Text="{Binding Name}"
                           AutomationId="BoxDetail_Entry_Name"
                           Placeholder="Collection name"
                           IsReadOnly="{Binding IsSystem}"
                           ReturnType="Done">
                        <Entry.Behaviors>
                            <behaviors:SelectAllOnFocusBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <BoxView Style="{StaticResource PickerInsetSeparator}" Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

    <!-- Save indicator -->
    <ActivityIndicator Style="{StaticResource SaveActivityIndicator}"
                       IsRunning="{Binding IsBusy}"
                       IsVisible="{Binding IsBusy}" />
    </Grid>
</ContentPage>
