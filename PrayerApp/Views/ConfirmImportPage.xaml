<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:behaviors="clr-namespace:PrayerApp.Behaviors"
             xmlns:shared="clr-namespace:PrayerApp.Views.Shared"
             x:Class="PrayerApp.Views.ConfirmImportPage"
             x:DataType="viewModels:ConfirmImportViewModel"
             Title="Confirm Import">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Cancel"
                     AutomationId="ConfirmImport_Btn_Cancel"
                     Priority="1"
                     x:DataType="viewModels:ConfirmImportViewModel"
                     Command="{Binding CancelCommand}" />
        <ToolbarItem Text="Save"
                     AutomationId="ConfirmImport_Btn_Save"
                     Priority="0"
                     x:DataType="viewModels:ConfirmImportViewModel"
                     Command="{Binding SaveCommand}"
                     SemanticProperties.Hint="Save the imported card and prayers" />
    </ContentPage.ToolbarItems>
    <ScrollView x:Name="RootScroll">
        <ScrollView.Behaviors>
            <behaviors:KeyboardScrollPaddingBehavior />
        </ScrollView.Behaviors>
        <VerticalStackLayout Padding="16" Spacing="10">

            <Label Text="Collection and Card Selection"
                   Style="{StaticResource FormSectionHeader}"
                   Margin="0,4,0,0" />

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="12">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Collection"
                           Style="{StaticResource FormLabel}" />
                    <shared:StyledPicker ItemsSource="{Binding AvailableBoxes}"
                                         SelectedItem="{Binding SelectedBox}"
                                         AutomationId="ConfirmImport_Picker_Box"
                                         SemanticHint="Choose which collection this imported card belongs to" />

                    <Label Text="Add to" Style="{StaticResource FormLabel}" />
                    <Grid Padding="3" ColumnDefinitions="*, *" ColumnSpacing="2">
                        <!-- New Card tab -->
                        <Border Grid.Column="0"
                                AutomationId="ConfirmImport_Seg_NewCard"
                                Padding="8,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 5"
                                BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsNewCardMode}"
                                             Value="True">
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="New Card"
                                   HorizontalTextAlignment="Center"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsNewCardMode}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                        <Setter Property="FontAttributes" Value="Bold" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetNewCardModeCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Existing Card tab -->
                        <Border Grid.Column="1"
                                AutomationId="ConfirmImport_Seg_ExistingCard"
                                Padding="8,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 5"
                                BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsExistingCardMode}"
                                             Value="True">
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Existing Card"
                                   HorizontalTextAlignment="Center"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsExistingCardMode}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                        <Setter Property="FontAttributes" Value="Bold" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetExistingCardModeCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <Label Text="Card Title"
                           Style="{StaticResource FormLabel}"
                           IsVisible="{Binding IsNewCardMode}" />
                    <Entry x:Name="CardTitleEntry"
                           Text="{Binding CardTitle}"
                           AutomationId="ConfirmImport_Entry_CardTitle"
                           Placeholder="Card title"
                           SemanticProperties.Hint="Title for the imported prayer card"
                           IsVisible="{Binding IsNewCardMode}"
                           HorizontalOptions="Fill">
                        <Entry.Behaviors>
                            <behaviors:SelectAllOnFocusBehavior />
                            <behaviors:KeyboardAvoidanceBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <BoxView Style="{StaticResource PickerInsetSeparator}" Margin="0,4,0,0"
                             IsVisible="{Binding IsNewCardMode}" />

                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout x:Name="cardGroupsList"
                                 BindableLayout.ItemsSource="{Binding AvailableCardGroups}"
                                 AutomationId="ConfirmImport_List_Groups"
                                 IsVisible="False"
                                 Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CardCollectionGroup">
                        <VerticalStackLayout Spacing="0" Margin="0,4,0,10">
                            <Label Text="{Binding CollectionName}"
                                   Style="{StaticResource PickerSectionHeader}"
                                   AutomationId="ConfirmImport_Lbl_GroupHeader"
                                   Margin="4,0,0,6" />
                            <Border Style="{StaticResource PickerGroupCard}">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Cards}"
                                                     Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewModels:CardPickerItem">
                                            <VerticalStackLayout Spacing="0">
                                                <Border Style="{StaticResource PickerRow}"
                                                        AutomationId="{Binding CardId, StringFormat='ConfirmImport_Item_{0}'}">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <Label Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               VerticalOptions="Center"
                                                               TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                                                        <Label Grid.Column="1"
                                                               Text="&#x2713;"
                                                               IsVisible="False"
                                                               VerticalOptions="Center"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="IsVisible" Value="True" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                    </Grid>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnCardItemTapped" />
                                                    </Border.GestureRecognizers>
                                                </Border>
                                                <BoxView Style="{StaticResource PickerInsetSeparator}" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Collapse-on-select summary row: visible after a card is selected.
                 Code-behind manages IsVisible + fade animation in OnVmPropertyChanged. -->
            <Border x:Name="selectedCardSummary"
                    Style="{StaticResource PickerGroupCard}"
                    Padding="16,13"
                    IsVisible="False">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="{Binding SelectedCard.Title}"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label Grid.Column="1"
                           Text="Change"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnChangeCardTapped" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Empty-state for Existing-Card mode when the selected
                 collection has no cards. Without this, the list area is
                 blank and the user reads it as "broken" rather than empty. -->
            <Label x:Name="noCardsLabel"
                   Text="No cards in this collection"
                   AutomationId="ConfirmImport_Lbl_NoCards"
                   IsVisible="{Binding HasNoAvailableCards}"
                   HorizontalTextAlignment="Center"
                   FontAttributes="Italic"
                   Padding="12,16"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />

            <Label Text="{Binding PrayersHeader}"
                   Style="{StaticResource FormSectionHeader}"
                   Margin="0,4,0,0" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Prayers}"
                                 AutomationId="ConfirmImport_List_Prayers"
                                 Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:EditablePrayer">
                        <Border Style="{StaticResource PrayerCardBorder}"
                                Padding="8"
                                Margin="0,0,0,6">
                            <VerticalStackLayout Spacing="4">

                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="4">
                                    <Entry Text="{Binding Title}"
                                           Placeholder="Prayer title"
                                           SemanticProperties.Description="Prayer title"
                                           VerticalOptions="Center">
                                        <Entry.Behaviors>
                                            <behaviors:SelectAllOnFocusBehavior />
                                            <behaviors:KeyboardAvoidanceBehavior />
                                        </Entry.Behaviors>
                                    </Entry>
                                    <Button Grid.Column="1"
                                            Text="✕"
                                            Clicked="OnRemovePrayerClicked"
                                            SemanticProperties.Description="Remove prayer"
                                            BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}"
                                            FontSize="14"
                                            Padding="4"
                                            BorderWidth="0"
                                            WidthRequest="32"
                                            HeightRequest="32" />
                                </Grid>

                                <Editor Text="{Binding Details}"
                                        Placeholder="Add details..."
                                        SemanticProperties.Description="Prayer details"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="48"
                                        HorizontalOptions="Fill">
                                    <Editor.Behaviors>
                                        <behaviors:KeyboardAvoidanceBehavior />
                                    </Editor.Behaviors>
                                </Editor>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="+ Add another prayer ›"
                    AutomationId="ConfirmImport_Btn_AddPrayer"
                    Command="{Binding AddPrayerCommand}"
                    FontSize="17"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    BackgroundColor="Transparent"
                    FontAttributes="Bold"
                    Padding="16,8,12,10"
                    BorderWidth="0"
                    HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
