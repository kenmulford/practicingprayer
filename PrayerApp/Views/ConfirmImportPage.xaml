<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.ConfirmImportPage"
             x:DataType="viewModels:ConfirmImportViewModel"
             Title="Confirm Import"
             SafeAreaEdges="All">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Border Style="{StaticResource PrayerCardBorder}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Card Title"
                           Style="{StaticResource FormLabel}" />
                    <Entry x:Name="CardTitleEntry"
                           Text="{Binding CardTitle}"
                           AutomationId="ConfirmImport_Entry_CardTitle"
                           Placeholder="Card title"
                           SemanticProperties.Hint="Title for the imported prayer card"
                           HorizontalOptions="Fill" />

                </VerticalStackLayout>
            </Border>

            <Label Text="Prayers"
                   Style="{StaticResource SectionHeading}"
                   Margin="0,4,0,0" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Prayers}"
                                 AutomationId="ConfirmImport_List_Prayers"
                                 Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:EditablePrayer">
                        <Border Style="{StaticResource PrayerCardBorder}"
                                Padding="12"
                                Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="8">

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Title"
                                           Style="{StaticResource FormLabel}"
                                           VerticalOptions="Center" />
                                    <Button Grid.Column="1"
                                            Text="✕"
                                            Clicked="OnRemovePrayerClicked"
                                            SemanticProperties.Description="Remove prayer"
                                            BackgroundColor="Transparent"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}"
                                            FontSize="14"
                                            Padding="4"
                                            BorderWidth="0"
                                            WidthRequest="32"
                                            HeightRequest="32" />
                                </Grid>
                                <Entry Text="{Binding Title}"
                                       Placeholder="Prayer title"
                                       HorizontalOptions="Fill" />

                                <Label Text="Details (optional)"
                                       Style="{StaticResource FormLabel}" />
                                <Editor Text="{Binding Details}"
                                        Placeholder="Add details..."
                                        HeightRequest="80"
                                        HorizontalOptions="Fill" />

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="+ Add another prayer"
                    AutomationId="ConfirmImport_Btn_AddPrayer"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding AddPrayerCommand}"
                    HorizontalOptions="Fill" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,40">
                <Button Grid.Column="0"
                        Text="Cancel"
                        AutomationId="ConfirmImport_Btn_Cancel"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Save"
                        AutomationId="ConfirmImport_Btn_Save"
                        Command="{Binding SaveCommand}"
                        SemanticProperties.Hint="Save the imported card and prayers"
                        HorizontalOptions="Fill" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
