<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:models="clr-namespace:PrayerApp.Models"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             xmlns:shared="clr-namespace:PrayerApp.Views.Shared"
             x:DataType="viewModels:HomeViewModel"
             x:Class="PrayerApp.Views.MainPage"
             SafeAreaEdges="Container">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16" Spacing="16">

                <!-- Action buttons — side by side -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="BtnQuickAdd"
                            Grid.Column="0"
                            Text="Quick Add"
                            AutomationId="Home_Btn_QuickAdd"
                            SemanticProperties.Hint="Add a prayer request"
                            HorizontalOptions="Fill" />
                    <Button x:Name="BtnPrayerTime"
                            Grid.Column="1"
                            Text="Prayer Time"
                            AutomationId="Home_Btn_PrayerTime"
                            SemanticProperties.Hint="Start a prayer session"
                            HorizontalOptions="Fill" />
                </Grid>

                <!-- 2x2 metric grid; row 2 holds a full-width "answered on this date" card -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                    <!-- Active Cards metric -->
                    <Border Grid.Row="0" Grid.Column="0"
                            AutomationId="Home_Metric_Cards"
                            SemanticProperties.Description="{Binding ActiveCardsAccessible}"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCardsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Style="{StaticResource MetricTileLabel}"
                                   Text="{Binding ActiveCardLabel}" />
                            <Label Style="{StaticResource MetricTileNumber}"
                                   Text="{Binding ActiveCardCount}"
                                   IsVisible="{Binding HasActiveCards}" />
                            <Label Style="{StaticResource MetricTileEmpty}"
                                   Text="No active cards"
                                   IsVisible="{Binding HasActiveCards, Converter={StaticResource InverseBool}}" />
                            <Label Style="{StaticResource MetricTileTapHint}"
                                   Text="{Binding ActiveCardTapHint}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Unanswered Prayers metric -->
                    <Border Grid.Row="0" Grid.Column="1"
                            AutomationId="Home_Metric_Unanswered"
                            SemanticProperties.Description="{Binding UnansweredAccessible}"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToPrayersCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Style="{StaticResource MetricTileLabel}"
                                   Text="{Binding UnansweredLabel}" />
                            <Label Style="{StaticResource MetricTileNumber}"
                                   Text="{Binding UnansweredCount}"
                                   IsVisible="{Binding HasUnanswered}" />
                            <Label Style="{StaticResource MetricTileEmpty}"
                                   Text="No prayers yet"
                                   IsVisible="{Binding HasUnanswered, Converter={StaticResource InverseBool}}" />
                            <Label Style="{StaticResource MetricTileTapHint}"
                                   Text="{Binding UnansweredTapHint}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Last Prayed date metric -->
                    <Border x:Name="LastPrayedCard" Grid.Row="1" Grid.Column="0"
                            AutomationId="Home_Metric_LastPrayed"
                            SemanticProperties.Description="{Binding LastPrayedAccessible}"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="0">
                            <Label Style="{StaticResource MetricTileLabel}"
                                   Text="Last Prayed"
                                   Margin="0,0,0,4" />
                            <Label Text="{Binding LastPrayedMonth}"
                                   IsVisible="{Binding HasLastPrayed}"
                                   FontSize="{StaticResource FontTiny}" FontAttributes="Bold" HorizontalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                            <Label Text="{Binding LastPrayedDay}"
                                   IsVisible="{Binding HasLastPrayed}"
                                   FontSize="{StaticResource FontHero}" FontAttributes="Bold" HorizontalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Style="{StaticResource MetricTileEmpty}"
                                   Text="Not yet"
                                   IsVisible="{Binding HasLastPrayed, Converter={StaticResource InverseBool}}" />
                            <Label Style="{StaticResource MetricTileTapHint}"
                                   Text="{Binding LastPrayedTapHint}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Overdue metric (gold highlight when has overdue) -->
                    <Border Grid.Row="1" Grid.Column="1"
                            AutomationId="Home_Metric_Overdue"
                            SemanticProperties.Description="{Binding OverdueAccessible}"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToOverdueCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding HasOverdue}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource OverdueLight}, Dark={StaticResource OverdueDark}}" />
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                                <!-- Issue #33 P1: PrayerCardBorder style flipped StrokeThickness default to 0.
                                     This DataTrigger writes Stroke; explicit StrokeThickness keeps the warm-gold
                                     overdue-state border visible. -->
                                <Setter Property="StrokeThickness" Value="1.5" />
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Style="{StaticResource MetricTileLabel}"
                                   Text="Overdue" />
                            <Label Text="{Binding OverdueCount}"
                                   IsVisible="{Binding HasOverdue}"
                                   FontSize="{StaticResource FontDisplayLg}" FontAttributes="Bold" HorizontalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                            <VerticalStackLayout IsVisible="{Binding HasOverdue, Converter={StaticResource InverseBool}}"
                                                 HorizontalOptions="Center" Spacing="0"
                                                 AutomationProperties.IsInAccessibleTree="False">
                                <Label Text="&#x2713;" FontSize="{StaticResource FontHeading}" HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource SuccessGreen}, Dark={StaticResource SuccessGreenDark}}" />
                                <Label Text="All requests have been recently prayed for." FontSize="{StaticResource FontCaption}" HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
                            </VerticalStackLayout>
                            <Label Style="{StaticResource MetricTileTapHint}"
                                   Text="View in Prayers &#x2192;"
                                   IsVisible="{Binding HasOverdue}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Answered prayers on this date in prior years (hidden when empty) -->
                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            AutomationId="Home_Card_AnsweredOnThisDate"
                            IsVisible="{Binding HasAnsweredOnThisDate}"
                            SemanticProperties.Description="{Binding AnsweredOnThisDateAccessible}"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding AnsweredOnThisDateHeader}"
                                   FontSize="{StaticResource FontSmall}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding AnsweredOnThisDate}"
                                                 Spacing="2"
                                                 Margin="0,4,0,0"
                                                 AutomationProperties.IsInAccessibleTree="False">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:Prayer">
                                        <Label Text="{Binding Title}"
                                               FontSize="{StaticResource FontSmall}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — PrayerTimeHighlight step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="PrayerTimeHighlight"
            HeadlineText="One last thing — Prayer Time lets you pray through your requests one by one"
            SubText="Tap the Prayer Time button above when you're ready. No rush!" />

        <shared:LoadingOverlay IsLoading="{Binding IsLoading}" />

    </Grid>
</ContentPage>
