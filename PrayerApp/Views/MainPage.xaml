<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:DataType="viewModels:HomeViewModel"
             x:Class="PrayerApp.Views.MainPage"
             SafeAreaEdges="Container">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16" Spacing="16">

                <!-- Action buttons — side by side -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="BtnQuickAdd"
                            Grid.Column="0"
                            Text="Quick Add"
                            AutomationId="Home_Btn_QuickAdd"
                            SemanticProperties.Hint="Add a prayer request"
                            HorizontalOptions="Fill" />
                    <Button x:Name="BtnPrayerTime"
                            Grid.Column="1"
                            Text="Prayer Time"
                            AutomationId="Home_Btn_PrayerTime"
                            SemanticProperties.Hint="Start a prayer session"
                            HorizontalOptions="Fill" />
                </Grid>

                <!-- Last prayed stat -->
                <Label Text="{Binding LastPrayedDisplay, StringFormat='Last prayed: {0}'}"
                       FontSize="13"
                       Style="{StaticResource MutedText}"
                       HorizontalOptions="Center" />

                <!-- Unified overdue card — always visible; content changes based on HasOverdue -->
                <Border Style="{StaticResource PrayerCardBorder}" Padding="16,14">
                    <VerticalStackLayout Spacing="0">

                        <!-- Header row: count + chevron (tappable when overdue) -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToOverdueCommand}" />
                            </Grid.GestureRecognizers>

                            <Label Text="{Binding OverdueHeadline}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   SemanticProperties.HeadingLevel="Level1"
                                   SemanticProperties.Hint="Double tap to view overdue prayers"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center" />

                            <!-- Chevron only visible when there are overdue items -->
                            <Label Grid.Column="1"
                                   Text="›"
                                   FontSize="22"
                                   IsVisible="{Binding HasOverdue}"
                                   AutomationProperties.IsInAccessibleTree="false"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Zero-state description — only shown when all caught up -->
                        <Label Text="{Binding OverdueEmptyDescription}"
                               IsVisible="{Binding HasOverdue, Converter={StaticResource InverseBool}}"
                               Style="{StaticResource MutedText}"
                               FontSize="13"
                               Margin="0,8,0,0" />

                        <!-- List section — only shown when there are overdue requests -->
                        <VerticalStackLayout IsVisible="{Binding HasOverdue}" Spacing="0">

                            <BoxView Style="{StaticResource DividerLine}" Margin="0,12,0,8" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding SuggestedPrayers}"
                                                 Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:SuggestedPrayerViewModel">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10"
                                              Padding="0,6">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectCommand}" />
                                            </Grid.GestureRecognizers>
                                            <Label Text="{Binding CardTitle}"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedText}"
                                                   VerticalOptions="Center"
                                                   WidthRequest="90" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding PrayerTitle}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   SemanticProperties.Hint="Double tap to view"
                                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — PrayerTime step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="PrayerTime"
            HeadlineText="Tap 'Prayer Time' when you're ready to pray"
            SubText="Choose 'All Requests' to get started" />

    </Grid>
</ContentPage>
