<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             x:DataType="viewModels:HomeViewModel"
             x:Class="PrayerApp.Views.MainPage"
             SafeAreaEdges="Container">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16" Spacing="16">

                <!-- Action buttons — side by side -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="BtnQuickAdd"
                            Grid.Column="0"
                            Text="Quick Add"
                            AutomationId="Home_Btn_QuickAdd"
                            SemanticProperties.Hint="Add a prayer request"
                            HorizontalOptions="Fill" />
                    <Button x:Name="BtnPrayerTime"
                            Grid.Column="1"
                            Text="Prayer Time"
                            AutomationId="Home_Btn_PrayerTime"
                            SemanticProperties.Hint="Start a prayer session"
                            HorizontalOptions="Fill" />
                </Grid>

                <!-- 2x2 Metric Grid -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                    <!-- Active Cards metric -->
                    <Border Grid.Row="0" Grid.Column="0"
                            AutomationId="Home_Metric_Cards"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCardsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding ActiveCardCount}"
                                   IsVisible="{Binding HasActiveCards}"
                                   FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="No active cards"
                                   IsVisible="{Binding HasActiveCards, Converter={StaticResource InverseBool}}"
                                   FontSize="13" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource TabUnselectedDark}}" />
                            <Label Text="{Binding ActiveCardLabel}"
                                   FontSize="11" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
                            <Label Text="{Binding ActiveCardTapHint}"
                                   FontSize="10" HorizontalOptions="Center" Margin="0,4,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Unanswered Prayers metric -->
                    <Border Grid.Row="0" Grid.Column="1"
                            AutomationId="Home_Metric_Unanswered"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToPrayersCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding UnansweredCount}"
                                   IsVisible="{Binding HasUnanswered}"
                                   FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="No prayers yet"
                                   IsVisible="{Binding HasUnanswered, Converter={StaticResource InverseBool}}"
                                   FontSize="13" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource TabUnselectedDark}}" />
                            <Label Text="{Binding UnansweredLabel}"
                                   FontSize="11" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
                            <Label Text="{Binding UnansweredTapHint}"
                                   FontSize="10" HorizontalOptions="Center" Margin="0,4,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Last Prayed date metric -->
                    <Border x:Name="LastPrayedCard" Grid.Row="1" Grid.Column="0"
                            AutomationId="Home_Metric_LastPrayed"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="0">
                            <Label Text="{Binding LastPrayedMonth}"
                                   IsVisible="{Binding HasLastPrayed}"
                                   FontSize="11" FontAttributes="Bold" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                            <Label Text="{Binding LastPrayedDay}"
                                   IsVisible="{Binding HasLastPrayed}"
                                   FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="Not yet"
                                   IsVisible="{Binding HasLastPrayed, Converter={StaticResource InverseBool}}"
                                   FontSize="13" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource TabUnselectedDark}}" />
                            <Label Text="Last Prayed"
                                   FontSize="11" HorizontalOptions="Center" Margin="0,2,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
                            <Label Text="{Binding LastPrayedTapHint}"
                                   FontSize="10" HorizontalOptions="Center" Margin="0,4,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Overdue metric (gold highlight when has overdue) -->
                    <Border Grid.Row="1" Grid.Column="1"
                            AutomationId="Home_Metric_Overdue"
                            Style="{StaticResource PrayerCardBorder}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToOverdueCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding HasOverdue}" Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource OverdueLight}, Dark={StaticResource OverdueDark}}" />
                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding OverdueCount}"
                                   IsVisible="{Binding HasOverdue}"
                                   FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}" />
                            <VerticalStackLayout IsVisible="{Binding HasOverdue, Converter={StaticResource InverseBool}}"
                                                 HorizontalOptions="Center" Spacing="0">
                                <Label Text="&#x2713;" FontSize="20" HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource SuccessGreen}, Dark={StaticResource SuccessGreenDark}}" />
                                <Label Text="All caught up!" FontSize="12" HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
                            </VerticalStackLayout>
                            <Label Text="Overdue"
                                   FontSize="11" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
                            <Label Text="View in Prayers &#x2192;"
                                   IsVisible="{Binding HasOverdue}"
                                   FontSize="10" HorizontalOptions="Center" Margin="0,4,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Onboarding coaching banner — PrayerTime step -->
        <onboarding:OnboardingBanner
            Grid.Row="1"
            ExpectedStep="PrayerTime"
            HeadlineText="Tap 'Prayer Time' when you're ready to pray"
            SubText="Choose 'All Requests' to get started" />

    </Grid>
</ContentPage>
