<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.PrayerTime.PrayerTimePage"
             x:DataType="viewModels:PrayerTimeViewModel"
             Title="Prayer Time"
             NavigationPage.HasNavigationBar="False">
    <ContentPage.BindingContext>
        <viewModels:PrayerTimeViewModel />
    </ContentPage.BindingContext>

    <!-- Toolbar items rendered manually since we hide the nav bar -->

    <Grid RowDefinitions="Auto, *, Auto" Padding="16">

        <!-- Row 0: Top bar (manual toolbar replacement) -->
        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Padding="0,8">
            <Button Grid.Column="0"
                    Text="← End"
                    Command="{Binding EndSessionCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontSize="14"
                    Padding="0" />
            <Label Grid.Column="1"
                   Text="{Binding ProgressDisplay}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="14"
                   TextColor="{StaticResource Gray400}" />
            <!-- Auto toggle placeholder — hidden until Task 3.5 wires it -->
            <Button Grid.Column="3"
                    Text="Auto ▷"
                    IsVisible="False"
                    FontSize="13"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}" />
        </Grid>

        <!-- Row 1: Card area (swipeable) -->
        <Grid Grid.Row="1" VerticalOptions="Center">

            <!-- The prayer card — hidden when loading or completed -->
            <Border BackgroundColor="{StaticResource Secondary}"
                    Stroke="{StaticResource Primary}"
                    StrokeThickness="1.5"
                    Padding="20"
                    IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <SwipeGestureRecognizer Direction="Left" Command="{Binding NextCommand}" />
                    <SwipeGestureRecognizer Direction="Right" Command="{Binding PreviousCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="12">
                    <!-- Card header (person/topic name) -->
                    <Label Text="{Binding CurrentEntry.CardTitle, FallbackValue=''}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Tertiary}" />
                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             HorizontalOptions="Fill"
                             Color="{StaticResource Primary}"
                             Opacity="0.4" />
                    <!-- Prayer request title -->
                    <Label Text="{Binding CurrentEntry.PrayerTitle, FallbackValue=''}"
                           FontSize="16"
                           TextColor="{StaticResource OffBlack}" />
                    <!-- Details (hidden if empty) -->
                    <Label Text="{Binding CurrentEntry.Details, FallbackValue=''}"
                           FontSize="14"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="{Binding CurrentEntry.Details, Converter={StaticResource StringToBool}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

            <!-- Completed overlay -->
            <VerticalStackLayout IsVisible="{Binding HasCompleted}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <Label Text="You've prayed through all your requests!"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Tertiary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Button Text="Finish"
                        Command="{Binding EndSessionCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

        </Grid>

        <!-- Row 2: Navigation arrows -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto, Auto, *" Padding="0,8"
              IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}">
            <Button Grid.Column="1"
                    Text="←"
                    Command="{Binding PreviousCommand}"
                    IsEnabled="{Binding HasPrevious}"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource Primary}"
                    FontSize="20"
                    WidthRequest="60"
                    HeightRequest="60"
                    CornerRadius="30" />
            <Button Grid.Column="2"
                    Text="→"
                    Command="{Binding NextCommand}"
                    IsEnabled="{Binding HasNext}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontSize="20"
                    WidthRequest="60"
                    HeightRequest="60"
                    CornerRadius="30" />
        </Grid>

    </Grid>
</ContentPage>
