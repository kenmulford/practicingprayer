<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.PrayerTime.PrayerTimePage"
             x:DataType="viewModels:PrayerTimeViewModel"
             Shell.NavBarIsVisible="False"
             xmlns:onboarding="clr-namespace:PrayerApp.Views.Onboarding"
             Shell.TabBarIsVisible="False">
    <ContentPage.BindingContext>
        <viewModels:PrayerTimeViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20,12,20,8">

        <!-- Row 0: Progress | [⏸/▶] [interval/countdown] — hidden when session completes -->
        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8"
              IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}">
            <Label Text="{Binding ProgressDisplay}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Style="{StaticResource MutedText}"
                   FontSize="13" />
            <!-- Pause/resume button — only visible while auto-mode is active -->
            <Label Grid.Column="1"
                   Text="{Binding PauseButtonText}"
                   IsVisible="{Binding IsAutoMode}"
                   VerticalOptions="Center"
                   Style="{StaticResource MutedText}"
                   FontSize="16">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding TogglePauseCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <!-- Countdown (auto-mode) or configured interval (manual mode); tap to cycle -->
            <Label Grid.Column="2"
                   Text="{Binding CountdownDisplay}"
                   VerticalOptions="Center"
                   Style="{StaticResource MutedText}"
                   FontSize="13">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CycleIntervalCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- Row 1: Prayer content — CarouselView for swipeable cards -->
        <Grid Grid.Row="1">

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

            <!-- Completed overlay -->
            <VerticalStackLayout IsVisible="{Binding HasCompleted}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <Label Text="You've prayed through all your requests!"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Button Text="Finish"
                        Command="{Binding EndSessionCommand}"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Swipeable prayer cards -->
            <CarouselView ItemsSource="{Binding Entries}"
                          Position="{Binding CurrentIndex, Mode=TwoWay}"
                          IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}"
                          Loop="False"
                          IsSwipeEnabled="True"
                          IsBounceEnabled="False"
                          HorizontalScrollBarVisibility="Never"
                          VerticalScrollBarVisibility="Never">
                <CarouselView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:PrayerTimeEntry">
                        <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="4,0">

                            <!-- Card title (small muted header) -->
                            <Label Text="{Binding CardTitle}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource PrimaryDark}}"
                                   Margin="0,8,0,0" />

                            <!-- Divider -->
                            <BoxView Grid.Row="1"
                                     Style="{StaticResource DividerLine}"
                                     Margin="0,6" />

                            <!-- Prayer title -->
                            <Label Grid.Row="2"
                                   Text="{Binding PrayerTitle}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />

                            <!-- Details with scroll + fade indicator -->
                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                <ScrollView VerticalScrollBarVisibility="Never">
                                    <Label Text="{Binding Details}"
                                           FontSize="17"
                                           LineHeight="1.5"
                                           Padding="0,0,0,28"
                                           TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}" />
                                </ScrollView>

                                <!-- Gradient fade at bottom — hints at scrollable content -->
                                <BoxView HeightRequest="36"
                                         VerticalOptions="End"
                                         InputTransparent="True">
                                    <BoxView.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0.0" />
                                            <GradientStop Color="{AppThemeBinding Light=#FAF8F3, Dark=#0d0e0c}" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

        </Grid>

        <!-- Row 2: [I'm done] [*] [←] [→] [*] [Auto] -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto, *, Auto, Auto, *, Auto"
              Padding="0,8"
              IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}">

            <Button Grid.Column="0"
                    Text="I'm done"
                    Command="{Binding EndSessionCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ButtonSecondaryLight}, Dark={StaticResource ButtonSecondaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                    Style="{StaticResource CircleNavButton}"
                    FontSize="11" />
            <Button Grid.Column="2"
                    Text="←"
                    Command="{Binding PreviousCommand}"
                    IsEnabled="{Binding HasPrevious}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ButtonSecondaryLight}, Dark={StaticResource ButtonSecondaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                    Style="{StaticResource CircleNavButton}" />
            <Button Grid.Column="3"
                    Text="→"
                    Command="{Binding NextCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                    Style="{StaticResource CircleNavButton}"
                    Margin="16,0,0,0" />
            <Button Grid.Column="5"
                    Text="{Binding AutoModeButtonText}"
                    Command="{Binding ToggleAutoModeCommand}"
                    IsEnabled="{Binding HasCompleted, Converter={StaticResource InverseBool}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ButtonSecondaryLight}, Dark={StaticResource ButtonSecondaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                    Style="{StaticResource CircleNavButton}"
                    FontSize="11" />

        </Grid>

        <!-- Onboarding coaching banner — PrayerTimeActive step -->
        <onboarding:OnboardingBanner
            Grid.Row="3"
            ExpectedStep="PrayerTimeActive"
            HeadlineText="Swipe through your cards. Tap &apos;I&apos;m done&apos; when finished."
            SubText="You can use the auto-advance timer too." />

    </Grid>
</ContentPage>
