<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.PrayerTime.PrayerTimePage"
             x:DataType="viewModels:PrayerTimeViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">
    <ContentPage.BindingContext>
        <viewModels:PrayerTimeViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *, Auto" Padding="20,12,20,8">

        <!-- Row 0: Progress + countdown only -->
        <Grid ColumnDefinitions="*, Auto">
            <Label Text="{Binding ProgressDisplay}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Style="{StaticResource MutedText}"
                   FontSize="13" />
            <Label Grid.Column="1"
                   Text="{Binding CountdownDisplay}"
                   VerticalOptions="Center"
                   Style="{StaticResource MutedText}"
                   FontSize="13">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CycleIntervalCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- Row 1: Prayer content — fills remaining screen estate -->
        <Grid Grid.Row="1">

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

            <!-- Completed overlay -->
            <VerticalStackLayout IsVisible="{Binding HasCompleted}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <Label Text="You've prayed through all your requests!"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Tertiary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Button Text="Finish"
                        Command="{Binding EndSessionCommand}"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Main prayer content -->
            <Grid RowDefinitions="Auto, Auto, Auto, *"
                  IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}">
                <Grid.GestureRecognizers>
                    <SwipeGestureRecognizer Direction="Left" Command="{Binding NextCommand}" />
                    <SwipeGestureRecognizer Direction="Right" Command="{Binding PreviousCommand}" />
                </Grid.GestureRecognizers>

                <!-- Card title (small muted header) -->
                <Label Text="{Binding CurrentEntry.CardTitle, FallbackValue=''}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Tertiary}"
                       Margin="0,8,0,0" />

                <!-- Divider -->
                <BoxView Grid.Row="1"
                         Style="{StaticResource DividerLine}"
                         Margin="0,6" />

                <!-- Prayer title -->
                <Label Grid.Row="2"
                       Text="{Binding CurrentEntry.PrayerTitle, FallbackValue=''}"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource White}}" />

                <!-- Details — dominant content, scrollable -->
                <ScrollView Grid.Row="3" Margin="0,12,0,0">
                    <Label Text="{Binding CurrentEntry.Details, FallbackValue=''}"
                           FontSize="17"
                           LineHeight="1.5"
                           TextColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource White}}" />
                </ScrollView>
            </Grid>

        </Grid>

        <!-- Row 2: [I'm done] [*] [←] [→] [*] [Auto] -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto, *, Auto, Auto, *, Auto"
              Padding="0,8"
              IsVisible="{Binding HasCompleted, Converter={StaticResource InverseBool}}">

            <Button Grid.Column="0"
                    Text="I'm done"
                    Command="{Binding EndSessionCommand}"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource Primary}"
                    Style="{StaticResource CircleNavButton}"
                    FontSize="11" />
            <Button Grid.Column="2"
                    Text="←"
                    Command="{Binding PreviousCommand}"
                    IsEnabled="{Binding HasPrevious}"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource Primary}"
                    Style="{StaticResource CircleNavButton}" />
            <Button Grid.Column="3"
                    Text="→"
                    Command="{Binding NextCommand}"
                    IsEnabled="{Binding HasNext}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Style="{StaticResource CircleNavButton}"
                    Margin="16,0,0,0" />
            <Button Grid.Column="5"
                    Text="{Binding AutoModeButtonText}"
                    Command="{Binding ToggleAutoModeCommand}"
                    IsEnabled="{Binding HasCompleted, Converter={StaticResource InverseBool}}"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource Primary}"
                    Style="{StaticResource CircleNavButton}"
                    FontSize="11" />

        </Grid>

    </Grid>
</ContentPage>
