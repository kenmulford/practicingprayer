<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="PrayerApp.Views.Onboarding.OnboardingCompletePopup"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
            Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource CardBorderDark}}"
            StrokeThickness="1"
            Margin="24,0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>

        <VerticalStackLayout Padding="28,32" Spacing="16">

            <Label Text="You're all set!"
                   FontSize="{StaticResource FontHeadingLg}"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                   SemanticProperties.HeadingLevel="Level1"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="Enjoy the app!"
                   FontSize="{StaticResource FontBodyLg}"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Button x:Name="BtnDone"
                    Text="Done"
                    AutomationId="Complete_Btn_Done"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
