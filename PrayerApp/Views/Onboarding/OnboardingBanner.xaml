<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrayerApp.Views.Onboarding.OnboardingBanner"
             IsVisible="False">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource SurfaceDark}}"
            StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12,12,0,0" />
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto,Auto,Auto,Auto" Padding="16,12,16,16" RowSpacing="4">

            <!-- Step indicator -->
            <Label x:Name="StepLabel"
                   Grid.Row="0"
                   TextColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}"
                   FontSize="{StaticResource FontTiny}"
                   FontAttributes="Bold"
                   CharacterSpacing="1" />

            <!-- Headline -->
            <Label x:Name="HeadlineLabel"
                   Grid.Row="1"
                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource TextPrimaryDark}}"
                   FontSize="{StaticResource FontBodyLg}"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />

            <!-- Sub text + skip link row -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">

                <Label x:Name="SubLabel"
                       Grid.Column="0"
                       TextColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource TextSecondaryDark}}"
                       FontSize="{StaticResource FontSmall}"
                       LineBreakMode="WordWrap" />

                <Button x:Name="SkipButton"
                        Grid.Column="1"
                        Text="Skip tour"
                        AutomationId="Banner_Btn_Skip"
                        TextColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource TextMutedDark}}"
                        BackgroundColor="Transparent"
                        FontSize="{StaticResource FontCaption}"
                        Padding="0"
                        BorderWidth="0"
                        VerticalOptions="End" />
            </Grid>

            <!-- Got It button (PrayerTimeHighlight only) -->
            <Button x:Name="GotItButton"
                    Grid.Row="3"
                    Text="Got it!"
                    AutomationId="Banner_Btn_GotIt"
                    IsVisible="False"
                    BackgroundColor="{AppThemeBinding Light={StaticResource WarmGold}, Dark={StaticResource WarmGoldDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                    FontSize="{StaticResource FontBody}"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="40"
                    Margin="0,8,0,0"
                    HorizontalOptions="Fill" />
        </Grid>
    </Border>
</ContentView>
