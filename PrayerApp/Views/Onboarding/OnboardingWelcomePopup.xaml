<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="PrayerApp.Views.Onboarding.OnboardingWelcomePopup"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
            Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource CardBorderDark}}"
            StrokeThickness="1"
            Margin="24,0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>

        <VerticalStackLayout Padding="28,32" Spacing="16">

            <Label Text="Welcome to Practicing Prayer"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="Let's set up your first prayer card."
                   FontSize="15"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Button x:Name="BtnGetStarted"
                    Text="Get Started"
                    Margin="0,8,0,0" />

            <Label x:Name="LblSkip"
                   Text="Skip tour"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}"
                   HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer x:Name="SkipTap" />
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
