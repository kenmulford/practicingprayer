<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PrayerApp.Views.Tags.TagDetailPage"
             x:DataType="viewModels:TagDetailViewModel"
             Title="Tag">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="24">

            <!-- System tag note -->
            <Border IsVisible="{Binding IsSystem}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,10">
                <Label Text="This is a system-managed tag. You can change its color, but not its name."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            </Border>

            <!-- Name field -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Name" Style="{StaticResource FormLabel}" />
                <Border Style="{StaticResource InputBorder}" Padding="10,0">
                    <Entry
                        Text="{Binding Name}"
                        Placeholder="Tag name"
                        IsReadOnly="{Binding IsSystem}"
                        ReturnType="Done" />
                </Border>
            </VerticalStackLayout>

            <!-- Color picker -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Color" Style="{StaticResource FormLabel}" />

                <FlexLayout Wrap="Wrap" Direction="Row"
                            AlignItems="Start" JustifyContent="Start">

                    <!-- Dynamic swatches from UserColor table -->
                    <BindableLayout.ItemsSource>
                        <Binding Path="Swatches" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ColorSwatchViewModel">
                            <Grid WidthRequest="48" HeightRequest="48" Margin="4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCommand}" />
                                </Grid.GestureRecognizers>
                                <Grid.Behaviors>
                                    <toolkit:TouchBehavior LongPressCommand="{Binding DeleteCommand}"
                                                           LongPressDuration="500" />
                                </Grid.Behaviors>
                                <!-- Color circle -->
                                <Ellipse
                                    Fill="{Binding SwatchColor}"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                                <!-- Selected ring -->
                                <Ellipse
                                    Stroke="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                    StrokeThickness="2"
                                    Fill="Transparent"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    IsVisible="{Binding IsSelected}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Add custom color button -->
                <Grid WidthRequest="48" HeightRequest="48" Margin="4,0,0,0"
                      HorizontalOptions="Start">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddColorCommand}" />
                    </Grid.GestureRecognizers>
                    <Ellipse
                        Stroke="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                        StrokeThickness="1.5"
                        StrokeDashArray="4,3"
                        Fill="Transparent"
                        WidthRequest="36"
                        HeightRequest="36"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                    <Label Text="+"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>

            <!-- Save button -->
            <Button
                Text="Save"
                Command="{Binding SaveCommand}"
                HorizontalOptions="Fill"
                Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
