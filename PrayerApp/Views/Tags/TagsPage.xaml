<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PrayerApp.ViewModels"
             x:Class="PrayerApp.Views.Tags.TagsPage"
             x:DataType="viewModels:TagsViewModel"
             Title="Tags">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding AddCommand}" />
    </ContentPage.ToolbarItems>

    <Grid>

    <!-- Loading indicator -->
    <ActivityIndicator IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}"
                       Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

    <CollectionView
        ItemsSource="{Binding Tags}"
        SelectionMode="None"
        Margin="10">

        <CollectionView.Header>
            <Label
                Text="Tags"
                Style="{StaticResource Headline}"
                Margin="20,20,20,10" />
        </CollectionView.Header>

        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="viewModels:TagItemViewModel">
                <SwipeView Threshold="80">
                    <SwipeView.LeftItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryBtnDark}}"
                                Command="{Binding EditCommand}"
                                SemanticProperties.Description="Edit tag"
                                Text="Edit" />
                        </SwipeItems>
                    </SwipeView.LeftItems>
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem
                                BackgroundColor="{AppThemeBinding Light={StaticResource DangerRed}, Dark={StaticResource DangerRed}}"
                                Command="{Binding DeleteCommand}"
                                SemanticProperties.Description="Delete tag"
                                Text="Delete" />
                        </SwipeItems>
                    </SwipeView.RightItems>

                    <Grid
                        Padding="20,14"
                        ColumnDefinitions="14, *, Auto, Auto"
                        ColumnSpacing="12"
                        MinimumHeightRequest="48"
                        HorizontalOptions="Fill">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EditCommand}" />
                        </Grid.GestureRecognizers>

                        <!-- Color dot -->
                        <BoxView
                            Grid.Column="0"
                            WidthRequest="14"
                            HeightRequest="14"
                            CornerRadius="7"
                            BackgroundColor="{Binding DotColor}"
                            VerticalOptions="Center"
                            AutomationProperties.IsInAccessibleTree="false" />

                        <!-- Tag name -->
                        <Label
                            Grid.Column="1"
                            Text="{Binding Name}"
                            FontSize="16"
                            SemanticProperties.Hint="Double tap to edit. Swipe left to delete, right to edit"
                            LineBreakMode="TailTruncation"
                            VerticalOptions="Center" />

                        <!-- System badge -->
                        <Border
                            Grid.Column="2"
                            IsVisible="{Binding IsSystem}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource SurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource CardBorderDark}}"
                            StrokeShape="RoundRectangle 8"
                            Padding="6,2"
                            VerticalOptions="Center">
                            <Label Text="System"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextSecondaryDark}}" />
                        </Border>

                        <!-- Chevron hint -->
                        <Label
                            Grid.Column="3"
                            Text="›"
                            FontSize="18"
                            AutomationProperties.IsInAccessibleTree="false"
                            TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource TextMutedDark}}"
                            VerticalOptions="Center" />
                    </Grid>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <Label
                Text="No tags yet. Tap Add to create your first tag."
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Margin="40,40"
                TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource TextMutedDark}}" />
        </CollectionView.EmptyView>
    </CollectionView>

    </Grid>
</ContentPage>
