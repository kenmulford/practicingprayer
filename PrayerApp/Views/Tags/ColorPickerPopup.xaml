<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="PrayerApp.Views.Tags.ColorPickerPopup">

    <Border StrokeShape="RoundRectangle 12"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource CardBorderDark}}"
            WidthRequest="320"
            Padding="16">
        <VerticalStackLayout Spacing="12">

            <!-- Saturation / Value picker area -->
            <GraphicsView x:Name="SvPicker"
                          HeightRequest="200"
                          HorizontalOptions="Fill"
                          StartInteraction="OnSvStartInteraction"
                          DragInteraction="OnSvDragInteraction" />

            <!-- Hue slider bar -->
            <GraphicsView x:Name="HueBar"
                          HeightRequest="28"
                          HorizontalOptions="Fill"
                          StartInteraction="OnHueStartInteraction"
                          DragInteraction="OnHueDragInteraction" />

            <!-- Hex display + color preview -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Padding="0,4,0,0">
                <Entry x:Name="HexEntry"
                       Placeholder="#RRGGBB"
                       MaxLength="7"
                       Keyboard="Text"
                       TextChanged="OnHexTextChanged"
                       HorizontalOptions="Fill" />
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 4"
                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource CardBorderDark}}"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0">
                    <BoxView x:Name="PreviewBox"
                             Color="Green"
                             WidthRequest="44"
                             HeightRequest="44" />
                </Border>
            </Grid>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Padding="0,4,0,0">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Style="{StaticResource GhostButton}"
                        Clicked="OnCancel"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="Add"
                        Clicked="OnAccept"
                        HorizontalOptions="Fill" />
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
